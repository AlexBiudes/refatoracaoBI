expression Parâmetro1 = #"Arquivo de Amostra" meta [IsParameterQuery=true, BinaryIdentifier=#"Arquivo de Amostra", Type="Binary", IsParameterQueryRequired=true]
	lineageTag: 8e580f9e-466d-4063-8056-39e9cfe47388
	queryGroup: 'Transformar Arquivo de Consulta1\Consultas Auxiliares'

	annotation PBI_ResultType = Binary

expression 'Transformar o Arquivo de Exemplo' =
		let
		    Fonte = Excel.Workbook(Parâmetro1, null, true),
		    Múltiplos_Sheet = Fonte{[Item="Múltiplos",Kind="Sheet"]}[Data]
		in
		    Múltiplos_Sheet
	lineageTag: b6586b69-814c-47c8-b4a6-592ea7442b96
	queryGroup: 'Transformar Arquivo de Consulta1'

	annotation PBI_ResultType = Table

expression 'Arquivo de Amostra' =
		let
		    Fonte = SharePoint.Files("https://planningassessoriaetributos.sharepoint.com/sites/BIPerformance", [ApiVersion = 15]),
		    #"Linhas Superiores Removidas" = Table.Skip(Fonte,1),
		    Navegação1 = #"Linhas Superiores Removidas"{0}[Content]
		in
		    Navegação1
	lineageTag: 43e9808b-4498-4a7d-bc4e-3035b898609a
	queryGroup: 'Transformar Arquivo de Consulta1\Consultas Auxiliares'

	annotation PBI_ResultType = Binary

expression 'Transformar Arquivo' =
		let
		    Fonte = (Parâmetro1 as binary) => let
		    Fonte = Excel.Workbook(Parâmetro1, null, true),
		    Múltiplos_Sheet = Fonte{[Item="Múltiplos",Kind="Sheet"]}[Data]
		in
		    Múltiplos_Sheet
		in
		    Fonte
	lineageTag: 268bcdcd-36ef-4736-8c55-74df7257a29e
	queryGroup: 'Transformar Arquivo de Consulta1\Consultas Auxiliares'

	annotation PBI_ResultType = Function

