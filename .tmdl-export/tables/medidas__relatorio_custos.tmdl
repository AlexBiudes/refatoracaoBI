	measure variacao_custo_ACU_video% =
			
			[custo_acumulado]
		lineageTag: 6ea31b84-25e9-4493-bf9b-cf4aa12600b4

		formatStringDefinition = ```
				VAR V_variacao_reais = [custo_acumulado] - [custo_acumuladoLY]
				VAR V_variacao = DIVIDE([custo_acumulado] - [custo_acumuladoLY], [custo_acumuladoLY])
				VAR V_formato = 
				SWITCH(
				    TRUE(),
				    V_variacao_reais >= 1000000000, "R$ #,#0,0B;R$ -#,#0,0B",
				    V_variacao_reais >= 1000000, "R$ #,#0,M; R$ -#,#0,M",
				    V_variacao_reais >= 1000, "R$ #,#0,K;R$ -#,#0,K",
				    "R$ #,#0,.00;R$ -#,#0,0.00"
				)
				VAR V_icone = 
				IF(V_variacao > 0, " ⇡", " ⇣")
				RETURN
				"""" & FORMAT(V_variacao_reais, V_formato) & " | " &
				"""" & FORMAT(V_variacao, "0%;-0%") &
				V_icone
				```

