			VAR vreceita =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "Receita Bruta"
			        ),
			        balancetenew[vlr]
			    )
			)
			RETURN
			DIVIDE([custo_total], vreceita)
			
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: a6412af2-05b5-443e-b5e6-6af238968da1

	measure custo_mes_atual_apagar = ```
			
			CALCULATE(
			    SUMX(Relatorio_Custos,
			        Relatorio_Custos[custo_total])
			   )
			
			```
		formatString: #,0
		lineageTag: 99ec7fc1-d17f-4142-b413-c785dba4565d

		annotation PBI_FormatHint = {"isDecimal":true}

	measure custo_medio_por_produto =
			
			COALESCE(
			    CALCULATE(
			    SUMX(
			    VALUES(Relatorio_Custos[descricao_item]),
			    DIVIDE(
			        CALCULATE(
			            SUM('Relatorio_Custos'[custo_total]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[descricao_item])
			        ),
			        CALCULATE(
			            SUM(Relatorio_Custos[quantidade]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[descricao_item])
			        )
			    )
			)
			)
			,0)
		lineageTag: e1aaad4d-aa1c-4769-9881-56a34074aae4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure %custos|receita_MEDIA_por_grupo_produto_ACU = ```
			
			
			    DIVIDE(
			            [custo_medio_por_grupo_produto],
			            [venda_media_por_grupo_produto_ACU]
			    )
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: f7223e23-510c-4eff-a06a-86f84d5d4534

	measure venda_media_por_grupo_produto_ACU =
			
			CALCULATE(
			SUMX(
			    VALUES(Relatorio_Custos[grupo_produto]),
			    DIVIDE(
			        CALCULATE(
			            SUM('Relatorio_Custos'[valor_unitario_venda]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[grupo_produto])
			        ),
			        CALCULATE(
			            SUM(Relatorio_Custos[quantidade]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[grupo_produto])
			        )
			    )
			), DATESYTD(dCalendario[data]))
		formatString: #,0
		lineageTag: acc448ae-ac66-468a-8156-3c045ab88117

		annotation PBI_FormatHint = {"isDecimal":true}

	measure custo_medio_por_grupo_produto_actual_month = ```
			
			/*VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			RETURN
			
			CALCULATE(
			SUMX(
			    VALUES(Relatorio_Custos[grupo_produto]),
			    DIVIDE(
			        CALCULATE(
			            SUM('Relatorio_Custos'[custo_total]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[grupo_produto])
			        ),
			        CALCULATE(
			            SUM(Relatorio_Custos[quantidade]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[grupo_produto])
			        )
			    )
			),
			dCalendario[data] >= UltimoMesTrimestre && 
			dCalendario[data] <= UltimoDiaTrimestre
			)*/
			
			DIVIDE(
			    [custo_mes_atual],
			    [quantidade_venda]
			)
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 2e00cc37-391f-434d-a020-eaa14c2d0a6e

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure custo_medio_por_grupo_produto_LM =
			
			CALCULATE(
			    [custo_medio_por_grupo_produto_actual_month],
			    DATEADD(dCalendario[data],
			    -1,
			    MONTH
			    )
			)
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: fb828488-f4e3-4f04-961a-84e292929f91

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure variacao$_custo_medio_grupo_prod_Actual_Month =
			
			VAR vcusto =
			[custo_medio_por_grupo_produto_actual_month] - [custo_medio_por_grupo_produto_LM]
			
			RETURN
			IF(ABS(vcusto) < 0.0001, 0, vcusto)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 165041ef-8bf8-4dd4-8282-46bf9705107c

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure variacao%_custo_medio_grupo_prod_Actual_Month =
			
