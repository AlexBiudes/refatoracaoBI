	measure variação_custos_totais = ```
			
			VAR v_variacao =
			    CALCULATE(
			        DIVIDE(
			            [custo_mes_atual] - [custo_mes_anterior],
			            [custo_mes_anterior]
			        )
			    )
			
			VAR v_seta =
			    IF(
			        v_variacao >= 0, "🡑", "🡓"
			    )
			
			VAR v_variacao_din =
			    [custo_mes_atual] - [custo_mes_anterior]
			
			VAR V_formato_moeda = 
			    SWITCH(
			        TRUE(),
			        v_variacao_din >= 1000000000, "R$ #,#0,0B;R$ -#,#0,0B",
			        v_variacao_din >= 1000000, "R$ #,#0,M;R$ -#,#0M",
			        v_variacao_din >= 1000, "R$ #,#0,K;R$ -#,#0K",
			        "R$ #,#0,0;R$ -#,#0,0"
			    )
			
			VAR v_formato_seta =
			    SWITCH(
			        TRUE(),
			        v_seta = "🡑",
			        v_seta = "🡓"
			    )
			
			RETURN
			FORMAT(v_seta, v_formato_seta) & " " &  
			FORMAT(v_variacao, "0.00%;-0.00%") 
			& " | " &
			FORMAT(v_variacao_din, V_formato_moeda)
			```
		lineageTag: 49d939d2-780f-4477-945e-b1876bd52796

