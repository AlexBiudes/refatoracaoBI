	measure custo_medio_por_produto_actual_month = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			    RETURN
			COALESCE(
			    CALCULATE(
			    SUMX(
			    VALUES(Relatorio_Custos[descricao_item]),
			    DIVIDE(
			        CALCULATE(
			            SUM('Relatorio_Custos'[custo_total]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[descricao_item])
			        ),
			        CALCULATE(
			            SUM(Relatorio_Custos[quantidade]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[descricao_item])
			        )
			    )
			), dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			, 0)
			
			
			```
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 015bd449-6ed2-402e-9d18-1a6cfaeef7f5

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure venda_media_por_produto_ACU =
			
			CALCULATE(
			SUMX(
			    VALUES(Relatorio_Custos[descricao_item]),
			    DIVIDE(
			        CALCULATE(
			            SUM('Relatorio_Custos'[valor_unitario_venda]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[descricao_item])
			        ),
			        CALCULATE(
			            SUM(Relatorio_Custos[quantidade]),
			            ALLEXCEPT('Relatorio_Custos', 'Relatorio_Custos'[descricao_item])
			        )
			    )
			), DATESYTD(dCalendario[data]))
		lineageTag: 68e14f58-98e2-4c59-8749-bf8dc5274b9e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure custo_mes_anterior = ```
			
