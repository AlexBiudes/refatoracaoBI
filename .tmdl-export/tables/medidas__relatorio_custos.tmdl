table medidas__relatorio_custos
	lineageTag: c7054f2b-02e4-452c-b664-5349f2b468b5

	measure Vendas_Mes_Atual = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			RETURN
			CALCULATE(
			    SUM(Relatorio_Custos[valor_total_venda]),
			    dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre
			)
			
			
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: a1c0ca7a-c892-494c-afde-c00fa7300b24

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure custo_mes_atual = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			RETURN
			COALESCE(
			CALCULATE(
			    SUM(Relatorio_Custos[custo_total]),
			    dCalendario[data] >= UltimoMesTrimestre && 
			        dCalendario[data] <= UltimoDiaTrimestre
			), 0)
			
			```
