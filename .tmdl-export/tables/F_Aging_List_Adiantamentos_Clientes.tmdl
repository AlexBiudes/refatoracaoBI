	column categoria_atraso_data_base = ```
			// Classifica o título em uma das categorias da tabela de dimensões "d_aging_list_dbase".
			var diferenca = DATEDIFF(
			                            F_Aging_List_Adiantamentos_Clientes[data_vencimento], F_Aging_List_Adiantamentos_Clientes[data_base], DAY
			                        ) 
			RETURN
			IF(F_Aging_List_Adiantamentos_Clientes[status_DB] = "Adiantado",
			  IF(diferenca <= 30, "Adiantados entre 0 e 30 dias",
			        IF(diferenca <= 60, "Adiantados entre 31 e 60 dias",
			            IF(diferenca <= 90, "Adiantados entre 61 e 90 dias",
			                IF(diferenca <= 120, "Adiantados entre 91 e 120 dias",
			                    IF(diferenca <= 180, "Adiantados entre 121 e 180 dias",
			                        IF(diferenca <= 360, "Adiantados entre 181 e 360 dias",
			                            IF(diferenca > 360, "Adiantados acima de 360 dias"
			                            )
			                        )
			                    )
			                )
			            )
			        )
			    ), "Em Aberto"
			)
			```
		lineageTag: e38dab6b-d72a-4a88-84d6-cc1258fee7c9
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

