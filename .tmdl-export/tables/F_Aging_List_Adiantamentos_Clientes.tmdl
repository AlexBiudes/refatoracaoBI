	column diferenca_data_base = ```
			
			VAR dif_data_emissao =
			DATEDIFF(
			    F_Aging_List_Adiantamentos_Clientes[data_emissao],
			F_Aging_List_Adiantamentos_Clientes[data_base],
			DAY
			)
			
			VAR dif_data_vencimento = 
			DATEDIFF(
			    F_Aging_List_Adiantamentos_Clientes[data_vencimento],
			F_Aging_List_Adiantamentos_Clientes[data_base],
			DAY
			)
			
			RETURN
			IF(ISBLANK(dif_data_emissao), dif_data_vencimento, dif_data_emissao)
			
			```
		formatString: 0
		lineageTag: f09ee216-8c3b-4a9a-937c-36e2f7a598dc
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column status_DB = ```
			IF(F_Aging_List_Adiantamentos_Clientes[diferenca_data_base] >= 0, "Adiantado", "Em Aberto") 
			```
		lineageTag: 156132de-4504-4219-9487-ee2ba1792d88
		summarizeBy: none

