	measure fornec_apagar =
			
			CALCULATE(
			SUM(balancetenew[vlr]),
			FILTER(balancetenew,
			balancetenew[Query] = "BL_PASSCIR_Fornecedores"))
		formatString: #,0
		lineageTag: a156031f-0978-4fa5-9f50-abb06cdcc0af

		annotation PBI_FormatHint = {"isDecimal":true}

	measure adiantamento_fornecedor_actual_month = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			    SUMX(F_Aging_List_Adiantamentos_Fornecedores,
			    F_Aging_List_Adiantamentos_Fornecedores[valor_pendente])
			    ,
			    dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: b9d3f89a-0daf-4e04-bc16-9dfc534ccbf7

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure adiantamento_clientes_actual_month = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			    SUMX(F_Aging_List_Adiantamentos_Clientes,
			    F_Aging_List_Adiantamentos_Clientes[valor_pendente]),
			    dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre
			    )
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 3493cb9b-aecd-4907-8036-5794ea95120f

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure adiantamento_clientes_LM =
			
			COALESCE(
			CALCULATE(
			    [adiantamento_clientes_actual_month], DATEADD(dCalendario[data], -1, MONTH)), 0)
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 58c75679-ee68-453b-9f7c-d0efba38038e

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure periodo_atual_aging = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			    MAX(dCalendario[Mês e Ano Abreviado]),
			    ALL(dCalendario),
			    VALUES(dCalendario[Mês e Ano Abreviado]
			    ),
			    dCalendario[data] = UltimoMesTrimestre
			)
			```
		lineageTag: ffa742c6-369c-4790-b628-76b6bd72c887

	measure periodo_anterior_aging =
			
			CALCULATE([periodo_atual_aging], DATEADD(dCalendario[data], -1, MONTH))
		lineageTag: 413fe4e5-9e86-43a3-812e-51af3767ba33

	measure %var_adto_clientes = ```
			
			VAR diferenca = [adiantamento_clientes_actual_month] - [adiantamento_clientes_LM]
			VAR variacao = DIVIDE(diferenca, [adiantamento_clientes_LM])
			VAR setas =
			    SWITCH(
			        TRUE(),
			        variacao > 0, " ⇡",
			        variacao < 0, " ⇣",
			        "Sem a Variação" 
			    )
			RETURN
			    setas & " " & FORMAT(variacao, "0.00%;-0.00%")
			```
		lineageTag: 416a45a4-4c54-4628-9e97-7b71d4ca1906

	measure adiantamento_fornecedor_LM =
			
			COALESCE(
			CALCULATE([adiantamento_fornecedor_actual_month], DATEADD(dCalendario[data], -1, MONTH)), 0)
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: b0248cbb-37fd-4678-82bc-ecf6450e83f3

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure %var_adto_fornecedores =
			
			VAR diferenca = [adiantamento_fornecedor_actual_month] - [adiantamento_fornecedor_LM]
			VAR variacao = DIVIDE(diferenca, [adiantamento_fornecedor_LM])
			VAR setas =
			    SWITCH(
			        TRUE(),
			        variacao > 0, " ⇡",
			        variacao < 0, " ⇣",
			        "Sem a Variação"
			    )
			RETURN
			    setas & " " & FORMAT(variacao, "0.00%;-0.00%")
		lineageTag: 6a64c179-fc19-426e-8593-0d2c5a83a330

