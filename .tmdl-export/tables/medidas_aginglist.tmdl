table medidas_aginglist
	lineageTag: 1dc44f5a-5f5c-4c24-86bc-727e99e6df18

	measure aging_diferença_dias_selecionado
		lineageTag: b5c899b4-ecb6-4a64-96e3-e1f14e6bb9a0

	measure fornecedores_aging = ```
			
			VAR UltimoDiaSelecionado = LASTDATE(dCalendario[data])
			RETURN
			COALESCE(
			CALCULATE(
			    SUM(F_Aging_List_Contas_Pagar[valor_pendente]),
			    FILTER(
			        ALL(dCalendario),
			        dCalendario[data] = UltimoDiaSelecionado
			    )
			),0)
			
			
			
			```
		formatString: #,0
		lineageTag: b8345311-cfdb-45ce-8744-a17f2de417b2

		annotation PBI_FormatHint = {"isDecimal":true}

	measure clientes_aging = ```
			
			VAR UltimoDiaSelecionado = LASTDATE(dCalendario[data])
			RETURN
			COALESCE(
			CALCULATE(
			    SUM(F_Aging_List_Contas_Receber[valor_pendente]),
			    FILTER(
			        ALL(dCalendario),
			        dCalendario[data] = UltimoDiaSelecionado
			    )
			), 0)
			
			
			```
		formatString: #,0
		lineageTag: bf79dd64-e6b0-4a35-bf20-9567d5428e8a

		annotation PBI_FormatHint = {"isDecimal":true}

	measure prazo_medio_contas_pagar_aging = ```
			
			VAR UltimoDiaSelecionado = LASTDATE(dCalendario[data])
			VAR FornecedoresAging = IF(
			    NOT(ISBLANK(medidas_aginglist[fornecedores_aging])), medidas_aginglist[fornecedores_aging], [PASSCIR_Fornecedores])
			VAR ComprasNoAnoAging = medidas_aginglist[Compras no ano_aging]
			VAR ValorMensal = Medidas_balancetenew[Valor_mensal_prazos_medios]
			
			RETURN
			//IF(
			  //  ISBLANK(FornecedoresAging) || ISBLANK(ComprasNoAnoAging) || ISBLANK(ValorMensal),
			    //BLANK(),
			    FornecedoresAging 
			     / ComprasNoAnoAging * ValorMensal
			// )
			
			```
		lineageTag: bd056135-b68b-4858-abb0-7808ed71c416

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure CCusto_ACU_Aging = ```
			
			IF(
			    SELECTEDVALUE(
			        d_clientes_time[tipo_analise], BLANK()
			    ) = "Ano Civil",
			CALCULATE(
			    SUMX(
			    FILTER(
			        balancetenew, 
			        balancetenew[Query] = "Custo dos Produtos Vendidos"
			    ), 
			        balancetenew[vlr]
			    ), 
			    DATESYTD(dCalendario[data]
			    )
			),
			[CCusto_selecionado_normal_card_aging]
			)
			```
		lineageTag: 7271cb4a-ba71-443a-afc7-513d21ee8032

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure CCusto_selecionado_aging =
			
			VAR MesSelecionado = SELECTEDVALUE(dCalendario[data])
			RETURN
			    CALCULATE(
			        SUMX(
			            FILTER(
			                balancetenew,
			                balancetenew[Query] = "Custo dos Produtos Vendidos" &&
			                balancetenew[data] <= MesSelecionado
			            ),
			            balancetenew[vlr]
			        ),
			        ALL(dCalendario[data])
			    )
		lineageTag: 4d751223-9eed-41e1-81a6-bfcf49ca3d7d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ATCIR_Estoques_aging =
			
			CALCULATE(
			    SUM(balancetenew[vlr]),
			    FILTER(
			        balancetenew,
			        balancetenew[Query] = "BL_ATCIR_Estoques" &&
			        balancetenew[data] = MAX(balancetenew[data])
			    )
			)
		lineageTag: ef33387e-921e-432d-9c50-46c7e5e4983f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure ATCIR_Estoques_End_of_LY_aging =
			
			CALCULATE(
			    'medidas_aginglist'[ATCIR_Estoques_aging],
			    FILTER(
			        ALL(dCalendario),
			        YEAR(dCalendario[data]) = YEAR(MAX(dCalendario[data])) - 1
			            && MONTH(dCalendario[data]) = 12
			    )
			)
		lineageTag: 18440475-e318-4feb-9b59-2fb16da83984

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Compras no ano_aging' = ```
			
			medidas_aginglist[CCusto_ACU_Aging] *-1 + 
			medidas_aginglist[ATCIR_Estoques_aging] - 
			medidas_aginglist[ATCIR_Estoques_End_of_LY_aging]
			```
		lineageTag: 2abc866f-3df6-4b22-a70e-0d616230158b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure CCusto_selecionado_normal_card_aging = ```
			
			SUMX(
			        FILTER(balancetenew, 
			        balancetenew[Query] = "Custo dos Produtos Vendidos"
			        ),
			    balancetenew[vlr]
			)
			```
		lineageTag: a722a0e2-498f-43e1-928c-85e8a194c6cb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure teste_prazo_pgto = ```
			
			    medidas_aginglist[fornecedores_aging] / 
			    medidas_aginglist[Compras no ano_aging] * 
			    [Valor_mensal]
			```
		lineageTag: 0178c63a-160c-45af-ac2e-22badd9e124b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure prazo_medio_contas_pagar_aging_LM = ```
			
			CALCULATE(
			    [prazo_medio_contas_pagar_aging], 
			    DATEADD(dCalendario[data], -1, MONTH
			    ))
			```
		lineageTag: 990331c2-324a-4104-b223-908cadc469c6

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure prazo_medio_giro_estoque_aging =
			
			VAR UltimoDiaSelecionado = LASTDATE(dCalendario[data])
			VAR Estoquesaging = medidas_aginglist[ATCIR_Estoques_aging]
			VAR CustoAcumAging = medidas_aginglist[CCusto_ACU_Aging]
			VAR ValorMensal = Medidas_balancetenew[Valor_mensal_prazos_medios]
			
			RETURN
			COALESCE(
			IF(
			    ISBLANK(Estoquesaging) || ISBLANK(CustoAcumAging) || ISBLANK(ValorMensal),
			    BLANK(),
			    Estoquesaging / CustoAcumAging * ValorMensal
			), 0) *-1
		lineageTag: ec857839-5548-4340-a277-bff106e719a4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure prazo_medio_giro_estoque_aging_LM = ```
			
			CALCULATE(
			    [prazo_medio_giro_estoque_aging], 
			    DATEADD(
			        dCalendario[data], -1, MONTH
			    )
			)
			```
		lineageTag: 41f9661f-109d-457c-b1c4-29ca40495a6d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure receita_bruta_aging =
			
			SUMX(
			    FILTER(balancetenew,
			    balancetenew[Query] = "Receita Bruta"
			    ),
			    balancetenew[vlr]
			    )
		lineageTag: cc7f2348-90ad-4a1e-b9cc-266879fd9e42

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure deducoes_aging =
			
			SUMX(
			    FILTER(balancetenew,
			    balancetenew[Query] = "Deduções da Receita Bruta"
			    ),
			    balancetenew[vlr]
			)
		lineageTag: e2dfefdc-8046-4a92-9b27-35dbd278043e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure vendas_menos_deducoes_aging =
			
			[receita_bruta_aging] + [deducoes_aging]
		lineageTag: e3622ccc-f6a9-4e38-9856-d6f970b3981a

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure prazo_medio_contas_receber_aging =
			
			VAR UltimoDiaSelecionado = LASTDATE(dCalendario[data])
			VAR ClientesAging = medidas_aginglist[clientes_aging]
			VAR VendasNoAnoAging = [vendas_menos_deducoes_aging_ACU]
			VAR ValorMensal = Medidas_balancetenew[Valor_mensal_prazos_medios]
			
			RETURN
			IF(
			    ISBLANK(ClientesAging) || ISBLANK(VendasNoAnoAging) || ISBLANK(ValorMensal),
			    BLANK(),
			    DIVIDE(
			    ClientesAging, VendasNoAnoAging) * ValorMensal
			)
		lineageTag: 30d72a9f-4f54-41f8-ae58-5b40936c54bb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure prazo_medio_contas_receber_aging_LM = ```
			
			CALCULATE(
			    [prazo_medio_contas_receber_aging], 
			    DATEADD(dCalendario[data], -1, MONTH)
			)
			
			```
		lineageTag: deee67d3-0300-43d6-a26a-835e9ae03cc3

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure vendas_menos_deducoes_aging_ACU = ```
			
