	column contagem_inv =
			
			VAR MaxDate = MAXX(ALL(dCalendario), [data])
			
			    RETURN DATEDIFF([data], MaxDate, MONTH) + 1
		formatString: 0
		lineageTag: e5a7ed42-8cda-460c-b680-0e6ca8d627db
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

