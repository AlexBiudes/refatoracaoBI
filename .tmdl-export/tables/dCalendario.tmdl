	partition dCalendario-5647c0b9-a269-475d-b0c3-ccb1bf91bd4a = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				     FILTER(
				        CALENDAR(DATE(2010, 1, 1), DATE(YEAR(TODAY())+1, 12, 31)),
				        YEAR([Date]) >= 2010 && YEAR([Date]) <= YEAR(TODAY())+1),
				    "Data Com Hora", DATE(YEAR([Date]), MONTH([Date]), DAY([Date])),
				    "Ano", YEAR([Date]),
				    "Mês Num", MONTH([Date]),
				    "Trim", FORMAT([Date], "q"),
				    "Semana Ano", WEEKNUM([Date]),
				    "Dia Semana", WEEKDAY([Date]),
				    "Mês", FORMAT([Date], "mmm"),
				    "Mês Completo", CONCATENATE(UPPER(LEFT(FORMAT([Date], "mmmm"), 1)), RIGHT(FORMAT([Date], "mmmm"), LEN(FORMAT([Date], "mmmm"))-1)),
				    "NuMês/Ano", FORMAT([Date],"mm/yyyy"),
				    "NoMês/Ano", UPPER(FORMAT([Date], "mmm/yyyy")),
				    "Trim-Ano", FORMAT([Date], "q") & "T" & YEAR([Date]),
				    "Dia_Semana", FORMAT([Date], "ddd"),
				    "Ano_Anterior", YEAR([Date]) - 1,
				    "Mês_Ano_Anterior", MONTH([Date]) -12,
				    "Mês e Ano", FORMAT([Date], "mmmm / yyyy"),
				    "Ordenação", YEAR([Date]) * 100 + MONTH([Date]),// Criando uma coluna para ordenação
				    "Ordenação Mês Ano Anterior", YEAR([Date]) * 12 + MONTH([Date]) - 1,
				    "Mês e Ano Abreviado", UPPER(((FORMAT([Date], "Mmm yyyy")))),
				    "Mês e Ano Abreviado Invert", UPPER(((FORMAT([Date], "Mmm yyyy")))),
				    "Mês e Ano Ano Anterior", UPPER(FORMAT(DATE(YEAR([Date]) - 1, MONTH([Date]), 1), "mmm yyyy"))
				
				
				)

	annotation PBI_Id = a2ddf2e1482d40f488be882466157f10

