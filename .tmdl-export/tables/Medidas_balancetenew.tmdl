	measure financiamentos_CP =
			
			VAR UltimaDataSelecionada = LASTDATE(dcalendario[data])  // Armazena a última data selecionada no filtro
			RETURN
			CALCULATE(
			    SUMX(
			        FILTER(
			             balancetenew,
			             balancetenew[Query] = "BL_PASSCIR_Emprestimos_Financiamentos" &&
			           ( balancetenew[descricao_cliente] = "FINANCIAMENTO BANCO HONDA SA" ||
			             balancetenew[descricao_cliente] = "BANCO J. SAFRA E LEASING" ||
			             balancetenew[descricao_cliente] = "FINANCIAMENTO BANCO SAFRA 135620" ||
			             balancetenew[descricao_cliente] = "( - ) JUROS S/ FINANCIAMENTO BANCO HONDA SA" ||
			             balancetenew[descricao_cliente] = "( ) ENCARGOS FINANC BANCO SAFRA 135620"
			
			             ) &&
			            balancetenew[data] = UltimaDataSelecionada  // Filtra pela última data
			        ),
			        balancetenew[total_mes_atual]
			    )
			)
		formatString: "R$"\ #,0.00;-"R$"\ #,0.00;"R$"\ #,0.00
		lineageTag: 04aa8a23-5b54-4ddf-a184-95e0fae1b745

