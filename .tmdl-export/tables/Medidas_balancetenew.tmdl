	measure outras_despesas_ = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			RETURN
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_tributarias" || 
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_despesas_operacionais"
			        ),
			        balancetenew[vlr]
			    ),
			    dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			```
		lineageTag: 3e37a01e-0176-4ad9-a702-0abe3175d3bb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

