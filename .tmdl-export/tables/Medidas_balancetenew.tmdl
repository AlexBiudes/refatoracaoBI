			                balancetenew[Query] = "Deduções da Receita Bruta" || 
			                balancetenew[Query] = "DRE_Imp_Incidentes_Sobre_Receita" ||
			                balancetenew[Query] = "Custo dos Produtos Vendidos" ||
			                balancetenew[Query] = "Custo dos Serviços" ||
			                balancetenew[Query] = "custo_vendas"
			            ),
			                dCalendario[data] = UltimoMesTrimestre
			    ))
