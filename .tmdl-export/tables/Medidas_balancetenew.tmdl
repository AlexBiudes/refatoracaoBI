	measure Analise_Horizontal_Ativos_Short = ```
			
			VAR Var_AT = [desvio%_ativo_total]
			VAR Var_AC = [desvio%_ativo_circulante]
			VAR Var_ANC = [desvio%_ativo_n_circulante]
			
			VAR TopTable =
			    FILTER(
			        ALL( 'balancetenew' ),
			        'balancetenew'[Query] IN { "BL_AT_soma", "BL_ATCIR_soma", "BL_ATNCIR_soma" }
			    )
			
			VAR RowMax = TOPN( 1, TopTable, [desvio%], DESC )
			VAR RowMin = TOPN( 1, TopTable, [desvio%], ASC )
			
			VAR NomeMax = LEFT( CONCATENATEX( RowMax, 'balancetenew'[Query], "," ), 24 )
			VAR NomeMin = LEFT( CONCATENATEX( RowMin, 'balancetenew'[Query], "," ), 24 )
			
			VAR ValorMax = MAXX( RowMax, [desvio%] )
			VAR ValorMin = MINX( RowMin, [desvio%] )
			
			RETURN
			IF(
			    ISBLANK( Var_AT ) && ISBLANK( Var_AC ) && ISBLANK( Var_ANC ),
			    BLANK(),
			    "AT:" & FORMAT( Var_AT, "0.00%" ) &
			    " AC:" & FORMAT( Var_AC, "0.00%" ) &
			    " ANC:" & FORMAT( Var_ANC, "0.00%" ) &
			    " | Max:" & NomeMax & ":" & FORMAT( ValorMax, "0.00%" ) &
			    " Min:" & NomeMin & ":" & FORMAT( ValorMin, "0.00%" )
			)
			
			```
		lineageTag: e3583f66-c1b8-4bc5-be1d-06653dcefae4

