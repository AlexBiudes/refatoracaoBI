			                    font-size:10px;
			                    color:#6B7A8C;
			                    font-weight:600;
			                    white-space:nowrap;
			                '>
			                    Dia " & FORMAT(DiaRecebimentos, "0") & "
			                </div>
			                <div style='
			                    position:absolute;
			                    left:" & PctRecebimentos & "%;
			                    top:74px;
			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    text-align:center;
