	measure gastos_gerais$_actual_month = ```
			
			VAR vdiferenca_margem_lucro =
			[MMargem_bruta_actual_month] - [rresultado_operacional]
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			RETURN
			CALCULATE(
			vdiferenca_margem_lucro,
			dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			```
