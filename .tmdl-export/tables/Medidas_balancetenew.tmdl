			VAR LiquidezGeralHTML = "<li style='margin: 10px 0; font-size: 12px;'><span style='color: #000;'>+</span> <span style='color: #000;'>1,65</span> * Índice de Liquidez Geral <span style='color: #555;'> " & FORMAT([lliquidez geral], "0.00") & " </span></li>"
