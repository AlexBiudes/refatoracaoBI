	measure MMargem_Bruta_acu_LY = ```
			
			VAR v_margem_acu_LY =
			IFERROR(
			    CALCULATE(
			    TOTALYTD(
			    [MMargem_bruta],
			    SAMEPERIODLASTYEAR(dCalendario[data])
			    )
			), BLANK())
			
			VAR v_margem_acu_selecionado_LY =
			IFERROR(
			    CALCULATE(
			    [MMargem_Bruta_ACU],
			    SAMEPERIODLASTYEAR(dCalendario[data]),
			    ALL(dCalendario)
			), BLANK())
			
			RETURN
			IF(
			    SELECTEDVALUE(
			        d_clientes_time[tipo_analise], BLANK()
			    ) = "Ano Civil",
			    v_margem_acu_LY,
			    v_margem_acu_selecionado_LY
			)
			
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 8e5bd139-7151-4a2f-8c9b-a4cf8003f929

