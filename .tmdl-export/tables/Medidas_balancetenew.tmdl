	measure variacao%_receita_bruta_ACU_video = [variacao_receita_bruta_ACU]
		lineageTag: d303dee2-3d61-4cb0-8e48-cfadebc96177

		formatStringDefinition = ```
				VAR V_receita = [variacao_receita_bruta$_ACU]
				VAR V_variacao = [variacao_receita_bruta_ACU]
				VAR V_formato = 
				SWITCH(
				    TRUE(),
				    V_receita >= 1000000000, "R$ #,#0,0B;R$ -#,#0,0B",
				    V_receita >= 1000000, "R$ #,#0,M; R$ -#,#0,M",
				    V_receita >= 1000, "R$ #,#0,K;R$ -#,#0,K",
				    "R$ #,#0,.00;R$ -#,#0,0.00"
				)
				VAR V_icone = 
				IF(V_variacao > 0, " ⇡", " ⇣")
				RETURN
				"""" & FORMAT(V_receita, V_formato) & " | " &
				"""" & FORMAT(V_variacao, "0%;-0%") &
				V_icone
				```

