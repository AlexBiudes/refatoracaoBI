	measure 'Prazo Médio Contas a Pagar' = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			    VAR v_fornec_compras =
			    DIVIDE(
			    Medidas_balancetenew[Fornecedores liquidos], 
			    Medidas_balancetenew[Compras no ano])
			
			    RETURN
			    ROUNDDOWN(
			CALCULATE(
			     v_fornec_compras * 
			    Medidas_balancetenew[Valor_mensal_prazos_medios]
			    
			    //,dCalendario[data] = UltimoMesTrimestre
			), 0)
			```
