	measure faturamento_menos_deducoes = ```
			
			VAR MaxDate = MAX(dCalendario[data])  // Obtém a última data selecionada no contexto de filtro
			
			VAR vfaturamento =
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "receita bruta" &&
			            balancetenew[data] >= DATEADD(dCalendario[data], -12, MONTH) &&  // Considera os últimos 12 meses
			            balancetenew[data] <= MaxDate
			        ),
			        balancetenew[vlr]
			    )
			
			VAR vdeducoes =
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "Deduções da Receita Bruta" &&
			            balancetenew[data] >= DATEADD(dCalendario[data], -12, MONTH) &&  // Considera os últimos 12 meses
			            balancetenew[data] <= MaxDate
			        ),
			        balancetenew[vlr]
			    ) * -1  // Multiplica por -1 para subtrair as deduções
			
			RETURN
			    vfaturamento - vdeducoes
			
			```
		lineageTag: 5aaf769c-1c83-4d99-aa57-5435bdd6a651

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure CCusto|Receitabruta_ACU =
			
			VAR vcusto =
			[CCusto_ACU] *-1
			VAR vreceita =
			[MReceita_Bruta_ACU]
			
			RETURN
			DIVIDE(
			vcusto,
			vreceita
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 4cdc81ad-4871-4ae1-a52c-82cf44a4053d

	measure 'LLucro_liquido | Receita_Bruta_ACU' =
			
			DIVIDE(
			          [LLucro_liquido_ACU],
			            [MReceita_Bruta_ACU]
			        )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e72e9d5d-93f0-4b30-9721-4a077fe890b1

	measure cfs_impostos_recebidos_ACU =
			
			CALCULATE(
			SUMX(
			    FILTER(balancetenew,
			    balancetenew[Query] = "DRE_Imposto_de_Renda" ||
			    balancetenew[Query] = "DRE_Contribuicao_Social"),
			    balancetenew[vlr]),
