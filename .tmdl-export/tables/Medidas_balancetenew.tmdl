	/// calcula a receita bruta
	measure MReceita_bruta = ```
			
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "Receita Bruta"
			        ),
			        balancetenew[vlr]
			    ),
			    TOPN(1, balancetenew, balancetenew[data], DESC)
			)
			
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: b9a5a0ae-950c-40a4-a66c-391a4094df1e

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure liq|bruta = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			    DIVIDE(
			        SUMX('Medidas_balancetenew', 
			        'Medidas_balancetenew'[MReceita_Liquida]), 
			        SUMX(
			            Medidas_balancetenew,
			            Medidas_balancetenew[MReceita_bruta]
			        )
			    ),
			    dCalendario[data] = UltimoMesTrimestre
			)
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: bb608d91-d28d-43b7-b69d-01c864a62f61

	measure liq|brutaLM = CALCULATE('Medidas_balancetenew'[liq|bruta],DATEADD(dCalendario[data],-1,MONTH))
