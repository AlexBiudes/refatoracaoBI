table Medidas_balancetenew
	lineageTag: 3603c923-b033-450c-84aa-8d5a68abc2f3

	measure MReceita_Liquida = ```
			
			SUMX(
			    FILTER(balancetenew,
			        balancetenew[Query] = "Receita Bruta" || 
			        balancetenew[Query] = "Deduções da Receita Bruta" || 
			        balancetenew[Query] = "DRE_Imp_Incidentes_Sobre_Receita"
			    ),
			    balancetenew[vlr]
			    )
			
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 851fb383-47f4-46d2-942a-4b655da44fb8

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure MReceita_Liquida_LM = CALCULATE('Medidas_balancetenew'[MReceita_Liquida],DATEADD(dCalendario[data],-1,MONTH))
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: b40d8e71-32a3-4f01-8a52-7c77f7d39104

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure MReceita_Liquida_ACU = ```
			
			IF(
			    SELECTEDVALUE(
			        d_clientes_time[tipo_analise], BLANK()
			    ) = "Ano Civil",
			    CALCULATE(
			        [MReceita_Liquida],
			        DATESYTD(
			            dCalendario[data]
			        )
			    ),
			    Medidas_balancetenew[MReceita_liquida_selecionado]
			)
			
			
			
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 3fdb7b3d-ebef-481e-a90f-57853aeca12a

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure MReceita_Liquida_Acumulada_LY =
			
			IF(
			    SELECTEDVALUE(
			        d_clientes_time[tipo_analise], BLANK()
			    ) = "Ano Civil",
			    Medidas_balancetenew[MReceita_Liquida_acu_LY_normal_card],
			    Medidas_balancetenew[MReceita_Liquida_selecionado_LY_normal_card]
			)
