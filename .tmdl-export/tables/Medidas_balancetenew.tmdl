	measure saLdo_passivo_balancetenew_df_ass = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			    DIVIDE(
			    CALCULATE(
			        [saldo_passivo_balancetenew],
			        dCalendario[data] >= UltimoMesTrimestre && 
			        dCalendario[data] <= UltimoDiaTrimestre),
			        1000
			    )
			```
		formatString: #,0
		lineageTag: 4e8e744b-4bea-4355-b6d3-3c2eb1b19602

		annotation PBI_FormatHint = {"isDecimal":true}

