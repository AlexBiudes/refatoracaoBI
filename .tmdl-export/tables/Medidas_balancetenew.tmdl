			SUMX(
			    FILTER(
			        balancetenew, 
			        balancetenew[Query] = "BL_PASSCIR_Emprestimos_Financiamentos"
			    ), 
			        balancetenew[vlr]
			),
			dCalendario[data] = UltimoMesTrimestre
