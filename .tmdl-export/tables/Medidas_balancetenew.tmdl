			                    balancetenew[descricao_cliente] = "( - ) ENCARGOS CAPITAL DE GIRO ITAU LP 2281764577" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU LP 2281764577" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU LP 2258593744" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU LP" ||
			                    balancetenew[descricao_cliente] = "( - ) ENCARGOS CAPITAL DE GIRO ITAU LP 2258593744" ||
			                    balancetenew[descricao_cliente] = "( - ) ENCARGOS CAPITAL DE GIRO ITAU LP 2258595129" ||
			                    balancetenew[descricao_cliente] = "BANCO ALFA CONTA GARANTIDA" ||
