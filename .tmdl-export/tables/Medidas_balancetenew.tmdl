	measure DDespesaADM = ```
			
			VAR v_desp_adm =
			SUMX(
			FILTER(balancetenew,
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_administrativas"), balancetenew[vlr])
			
			VAR v_desp_ocupacao = 
			SUMX(
			    FILTER(balancetenew,
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Ocupacao"), balancetenew[vlr])
			
			VAR v_desp_depreciacao =
			SUMX(
			    FILTER(balancetenew,
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_depreciacao"), balancetenew[vlr])
			
			VAR despesas_agrologica =
			SUMX(
			    FILTER(balancetenew,
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Utilidades_Servicos" ||
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Servicos_Profissionais" ||
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Comunicacao" ||
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Viagens_Estadia" ||
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_Bancarias" ||
			balancetenew[Query] = "DRE_Desp_Operacionais_Despesass_com_Outras_Provisoes"
			), balancetenew[vlr])
			RETURN
			IF(
			    SELECTEDVALUE(
			        d_clientes_time[cnpj]) = "07134550000142",        
			v_desp_adm + v_desp_depreciacao + v_desp_ocupacao + despesas_agrologica,
			v_desp_adm + v_desp_depreciacao + v_desp_ocupacao
			)
			
			//SUMX(
			//    FILTER(balancetenew,
			//        balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_administrativas" || 
			//        balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Ocupacao" || 
			//        balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_depreciacao"),
			 //   balancetenew[vlr]
			//)
			
			
			```
