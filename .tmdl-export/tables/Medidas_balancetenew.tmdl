	measure switch_roic = ```
			
			VAR nopat_ = [LLucro_liquido II] - IF([receita_financeira] < 0, [receita_financeira]*-1, [receita_financeira]) + ([despesa_financeira]*-1) + [desp_nao_operacionais]
			VAR roic_ = 
			FORMAT(
			    DIVIDE(
			        nopat_,
			        [patrimonioLiq]
			    ), "0.00%"
			)
			
			RETURN
			SWITCH(
			    SELECTEDVALUE(
			        D_ROIC[nome]
			    ),
			    "(=) Lucro ou Prejuízo Líquido", [LLucro_liquido II],
			    "(-) Receita Financeira", [receita_financeira],
			    "(+) Despesa Financeira", [despesa_financeira],
			    "(+/-) Despesas não Operacionais", [desp_nao_operacionais],
			    "CAPITAL INVESTIDO (PL + Capital de Terceiros)", [patrimonioLiq] + [Emprestimos_CP] + [emprestimos_LP], /* feito a inclusão de emprestimos CP e LP a pedido de Matheus Fernandes em 11/02/2026 */
			    "ROIC", roic_,
			    "(=) NOPAT", nopat_
			
			)
			```
		lineageTag: 157a9ebf-ed01-4131-99e0-a9f64fbf281b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure switch_roic_LY = ```
			
			VAR nopat_LY = CALCULATE(
			    [LLucro_liquido] - [receita_financeira] + [despesa_financeira] + [desp_nao_operacionais],
			    DATEADD(dCalendario[data], -1, YEAR)
			)
			VAR roic_ = 
			FORMAT(
			    DIVIDE(
			        nopat_LY,
			        CALCULATE(
			        [patrimonioLiq],
			        DATEADD(dCalendario[data], -1, YEAR))
			    ), "0.00%")
			
			VAR roic_LY =
			CALCULATE(
			    roic_,
			    DATEADD(
			        dCalendario[data],
			        -1,
			        YEAR
			    )
			)
			RETURN
			SWITCH(
			    SELECTEDVALUE(
			        D_ROIC[nome]
			    ),
			    "(=) Lucro ou Prejuízo Líquido", [Lucro_liquido_LY],
			    "(-) Receita Financeira", CALCULATE([receita_financeira], DATEADD(dCalendario[data], -1, YEAR)),
			    "(+) Despesa Financeira", CALCULATE([despesa_financeira], DATEADD(dCalendario[data], -1, YEAR)),
			    "(+/-) Despesas não Operacionais", CALCULATE([desp_nao_operacionais], DATEADD(dCalendario[data], -1, YEAR)),
			    "CAPITAL INVESTIDO (PL + Capital de Terceiros)", CALCULATE([patrimonioLiq], DATEADD(dCalendario[data], -1, YEAR)),
			    "ROIC", roic_LY,
			    "(=) NOPAT", nopat_LY
			
			)
			```
		lineageTag: 3a962f6f-78d9-4af2-83bd-b445cd022b39

		annotation PBI_FormatHint = {"isGeneralNumber":true}

