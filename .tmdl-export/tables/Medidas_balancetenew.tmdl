			)
			
			VAR vreceitas_ly =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_receitas_operacionais"
			        ),
			        balancetenew[vlr]
			    ),
			    DATESYTD(DATEADD(dCalendario[data], -1, YEAR))
			)
			
			VAR vvariacao =
			DIVIDE(
			vreceitas - vreceitas_ly,
			vreceitas_ly)
			
			
			RETURN
			vvariacao
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: b9517412-30fd-45e4-9952-2b7192f66ed5

	measure var_outras_despesas_receitas_video = ```
			
			
			VAR vdespesas =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_tributarias" || 
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_despesas_operacionais"
			        ),
			        balancetenew[vlr]
			    ),
			    DATESYTD(dCalendario[data])
			)
			
			VAR vreceitas =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_receitas_operacionais"
			        ),
			        balancetenew[vlr]
			    ),
			    DATESYTD(dCalendario[data])
			)
			
			VAR vdespesas_ly =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_tributarias" || 
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_despesas_operacionais"
			        ),
			        balancetenew[vlr]
			    ),
			    DATESYTD(DATEADD(dCalendario[data], -1, YEAR))
			)
			
			VAR vreceitas_ly =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_receitas_operacionais"
			        ),
			        balancetenew[vlr]
			    ),
			    DATESYTD(DATEADD(dCalendario[data], -1, YEAR))
			)
			
			VAR vvariacao_despesas = vdespesas - vdespesas_ly
			VAR vvariacao_receitas = vreceitas - vreceitas_ly
			
			VAR resultado_despesas =
			IF(
			    vvariacao_despesas > 0,
			    "▲ Aumento de " & FORMAT(vvariacao_despesas, "0.00"),
			    "▼ Redução de " & FORMAT(vvariacao_despesas, "0.00")
			)
			
			VAR resultado_receitas =
			IF(
			    vvariacao_receitas > 0,
			    "▲ Aumento de " & FORMAT(vvariacao_receitas, "0.00"),
			    "▼ Redução de " & FORMAT(vvariacao_receitas, "0.00")
			)
			
			RETURN
			"Despesas: " & resultado_despesas & " | Receitas: " & resultado_receitas
			
			```
		lineageTag: d7458c5d-57b1-47a2-996c-9467db97e183

