	measure 'Prazo Médio do Giro do Estoque' = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			    DIVIDE(
			    Medidas_balancetenew[ATCIR_Estoques] ,
			    Medidas_balancetenew[CCusto_ACU]) * Medidas_balancetenew[Valor_mensal_prazos_medios] * -1
			    //, dCalendario[data] = UltimoMesTrimestre
			)
			```
