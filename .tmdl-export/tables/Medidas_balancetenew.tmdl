	measure mreceita_liquida_selecionado_LY_kpi =
			
			VAR MinData =
			    CALCULATE ( MIN ( 'dCalendario'[Data] ), ALLSELECTED ( 'dCalendario' ) )
			VAR MaxData =
			    CALCULATE ( MAX ( 'dCalendario'[Data] ), ALLSELECTED ( 'dCalendario' ) )
			
			-- desloca o intervalo inteiro 12 meses para trás (LY)
			VAR MinDataLY = EDATE ( MinData, -12 )
			VAR MaxDataLY = EDATE ( MaxData, -12 )
			
			RETURN
			CALCULATE (
			    SUM ( balancetenew[vlr] ),
			    balancetenew[Query] IN {
			        "Receita Bruta",
			        "Deduções da Receita Bruta",
			        "DRE_Imp_Incidentes_Sobre_Receita"
			    },
			    'dCalendario'[Data] >= MinDataLY,
			    'dCalendario'[Data] <= MaxDataLY
			)
		lineageTag: 91387a96-d1ca-4371-9cdf-03919259ccc2

