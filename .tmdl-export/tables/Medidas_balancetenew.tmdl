			    box-sizing:border-box;
			    width:100%;
			    color:#23384D;
			    overflow:hidden;
			'>
			
			    <div style='font-size:15px; font-weight:600; color:#26435C; margin-bottom:10px;'>
			        Timeline do Ciclo Financeiro
			    </div>
			
			    <div style='font-size:11px; font-weight:600; color:#6B7A8C; margin-bottom:18px;'>
			        Este Período
			    </div>
			
			    <div style='
			        display:flex;
			        align-items:center;
			        justify-content:space-between;
			        gap:36px;
			        flex-wrap:nowrap;
			        width:100%;
			    '>
			
			        <div style='
			            flex:1 1 auto;
			            min-width:0;
			            width:100%;
			        '>
			            <div style='position:relative; height:132px; width:100%;'>
			
			                <!-- linha base -->
			                <div style='
			                    position:absolute;
			                    left:0;
			                    right:0;
			                    top:58px;
			                    height:3px;
			                    background:#BFC9D4;
			                    border-radius:999px;
			                '></div>
			
			                <!-- seta -->
			                <div style='
			                    position:absolute;
			                    right:-1px;
			                    top:54px;
			                    width:0;
			                    height:0;
			                    border-top:5px solid transparent;
			                    border-bottom:5px solid transparent;
			                    border-left:12px solid #BFC9D4;
			                '></div>
			
			                <!-- faixa capital de giro -->
			                <div style='
			                    position:absolute;
			                    left:" & PctCGIni & "%;
			                    width:" & PctCGLarg & "%;
			                    top:57px;
			                    height:4px;
			                    background:" & CorCapitalGiro & ";
			                    border-radius:999px;
			                '></div>
			
			                <!-- Saída dos estoques -->
			                <div style='position:absolute; left:0; top:34px;'>
			                    <div style='width:6px; height:28px; background:#2F80ED; border-radius:999px;'></div>
			                </div>
			                <div style='
