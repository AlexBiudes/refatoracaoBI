			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			DIVIDE(
			Medidas_balancetenew[contas receber] * (-30 * 1),
			Medidas_balancetenew[MReceita_Liquida]
			),
			dCalendario[data] = UltimoMesTrimestre
			) *-1
