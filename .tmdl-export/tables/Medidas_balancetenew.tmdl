			VAR PctCGLarg       = SUBSTITUTE(FORMAT(PctCGLargNum, "0.0"), ",", ".")
			
			VAR CorCapitalGiro =
			    IF(DiasCapitalGiro < 0, "#D64545", "#2D9CDB")
			
			RETURN
			"
