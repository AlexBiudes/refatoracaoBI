	measure emprest_partes_relacionadas = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			    COALESCE(
			    IF(
			CALCULATE(
			    SUMX(
			        FILTER(balancetenew,
			        balancetenew[Query] = "BL_PASSNCIR_Partes_Relacionadas"
			        ),
			        balancetenew[total_mes_atual]
			    ),
			    dCalendario[data] = UltimoMesTrimestre
			) < 0,
			CALCULATE(
			    SUMX(
			        FILTER(balancetenew,
			        balancetenew[Query] = "BL_PASSNCIR_Partes_Relacionadas"
			        ),
			        balancetenew[total_mes_atual]
			    ),
			    dCalendario[data] = UltimoMesTrimestre
			) * -1,
			CALCULATE(
			    SUMX(
			        FILTER(balancetenew,
			        balancetenew[Query] = "BL_PASSNCIR_Partes_Relacionadas"
			        ),
			        balancetenew[total_mes_atual]
			    ),
			    dCalendario[data] = UltimoMesTrimestre
			)
			), 0)
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: c10c0c9e-205e-44c8-9386-c627fe89e21c

