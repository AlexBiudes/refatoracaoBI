			VAR LiquidezCorrenteHTML = "<li style='margin: 10px 0; font-size: 12px;'><span style='color: #000;'>-</span> <span style='color: #000;'>1,06</span> * Índice de Liquidez Corrente <span style='color: #555;'> " & FORMAT([lliquidez corrente], "0.00") & " </span></li>"
			VAR EndividamentoTotalHTML = "<li style='margin: 10px 0; font-size: 12px;'><span style='color: #000;'>-</span> <span style='color: #000;'>0,33</span> * Índice de Endividamento Total <span style='color: #555;'> " & FORMAT([Endividamento total], "0.00") & " </span></li>"
			
