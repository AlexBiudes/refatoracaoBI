	measure MMargem_Bruta_ACU = ```
			
			VAR v_margem_ano_civil = IFERROR(
			CALCULATE(
			        [MMargem_bruta],
			        DATESYTD(
			            dCalendario[data]
			        )
			    ), BLANK())
			
			VAR v_margem_selecionado = [MMargem_bruta_selecionado] 
			
			RETURN
			IF(
			    SELECTEDVALUE(
			        d_clientes_time[tipo_analise], BLANK()
			    ) = "Ano Civil",
			    v_margem_ano_civil,
			    v_margem_selecionado
			)
			
			```
