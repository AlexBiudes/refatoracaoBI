	measure MReceita_Liquida_actual_month = ```
			
			 VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			    RETURN
			    CALCULATE(
			SUMX(
			    FILTER(balancetenew,
			        balancetenew[Query] = "Receita Bruta" || 
			        balancetenew[Query] = "Deduções da Receita Bruta" || 
			        balancetenew[Query] = "DRE_Imp_Incidentes_Sobre_Receita"
			    ),
			    balancetenew[vlr]
			    ),
			    dCalendario[data] = UltimoMesTrimestre
			    )
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 98f8fc13-589b-450c-af53-4c17ccb75e86

