			        cp_variacao >= 0.71, "8",
			        cp_variacao >= 0.61, "7",
			        cp_variacao >= 0.51, "6",
			        cp_variacao >= 0.41, "5",
			        cp_variacao >= 0.31, "4",
			        cp_variacao >= 0.21, "3",
			        cp_variacao >= 0.11, "2",
			        cp_variacao >= 0, "1",
			        cp_variacao >= -0.10, "9",
			        cp_variacao >= -0.20, "10",
			        cp_variacao >= -0.30, "11",
			        cp_variacao >= -0.40, "12",
			        cp_variacao >= -0.50, "13",
			        cp_variacao >= -0.60, "14",
			        cp_variacao >= -0.70, "15",
			        "16"
			    )
			
			VAR interpret_var_comentario =
			    SWITCH(
			        var_emprest,
			        "8", "Aumento crítico, indicando uma dependência extrema de empréstimos.",
