	measure BL_ATCIR_total_ativo_circulante = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			    RETURN
			    CALCULATE(
			SUMX(
			    FILTER(
			        balancetenew, balancetenew[Query] = "BL_ATCIR_soma"
			        ), 
			        balancetenew[vlr]
			        ),
			        dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			```
		formatString: #,0
		lineageTag: 1bdeb6de-f2d8-46e3-9443-23150fce5a07

