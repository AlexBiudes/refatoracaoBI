	measure MMargem_bruta_actual_month = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			    CALCULATE(
			        SUM(
			            balancetenew[vlr]
			        ),
			        FILTER(
			                balancetenew,
			                balancetenew[Query] = "DRE_Lucro_bruto"
			            ),
			                dCalendario[data] = UltimoMesTrimestre
			    )
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
