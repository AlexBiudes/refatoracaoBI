	measure ppconew =
			
			VAR _passivo_circ = IF(
			    [ssomapasscircu] < 0,
			    [ssomapasscircu] *-1,
			    [ssomapasscircu]
			)
			VAR _emprestimos = IF(
			    [Emprestimos_Financiamentos] < 0,
			    [Emprestimos_Financiamentos] *-1,
			    [Emprestimos_Financiamentos]
			)
			
			RETURN
			_passivo_circ  - _emprestimos
		lineageTag: da032fd4-0963-44f0-8529-c9a2df7c0a76

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure NNecessidadeCPTgiro = ```
			
