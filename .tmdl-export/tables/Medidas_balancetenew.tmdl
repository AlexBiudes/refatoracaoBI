	measure ssomapasscircu = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			VAR _passivo_circulante =
			    CALCULATE(
			        SUMX(
			            FILTER(
			                balancetenew, 
			                balancetenew[Query] = "BL_PASSCIR_soma"
			                ), 
			                balancetenew[vlr]) *-1,
			dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			
			RETURN
			IF(_passivo_circulante < 0,
			    _passivo_circulante *-1,
			    _passivo_circulante
			)
			```
