	measure 'narrativa_emprestEFinanc II' = ```
			
			VAR cp_ratio = DIVIDE([eemprestEFinanc_CP], [ssomaemprestEfinan])
			VAR lp_ratio = DIVIDE([eemprestEFinanc_LP], [ssomaemprestEfinan])
			VAR proporcao_passivo =
			DIVIDE([eemprestEFinanc_CP] + [eemprestEFinanc_LP], [totpassivo II])
			VAR passivo_ratio = 
			    SWITCH(
			        TRUE(),
			        proporcao_passivo >= 0.71, "entre 71% e 100%",
			        proporcao_passivo >= 0.51, "entre 51% e 70%",
			        proporcao_passivo >= 0.21, "entre 21% e 50%",
			        "entre 1% e 20%"
			    )
			VAR cenario = 
			    SWITCH(
			        TRUE(),
			        cp_ratio >= 0.99 && cp_ratio <= 1 && lp_ratio <= 0.01 && passivo_ratio = "entre 1% e 20%", 1,
			        cp_ratio >= 0.99 && cp_ratio <= 1 && lp_ratio <= 0.01 && passivo_ratio = "entre 21% e 50%", 2,
			        cp_ratio >= 0.99 && cp_ratio <= 1 && lp_ratio <= 0.01 && passivo_ratio = "entre 51% e 70%", 3,
			        cp_ratio >= 0.99 && cp_ratio <= 1 && lp_ratio <= 0.01 && passivo_ratio = "entre 71% e 100%", 4,
			        cp_ratio <= 0.20 && lp_ratio >= 0.80 && passivo_ratio = "entre 1% e 20%", 5,
			        cp_ratio >= 0.21 && cp_ratio <= 0.50 && lp_ratio >= 0.50 && lp_ratio <= 0.79 && passivo_ratio = "entre 1% e 20%", 6,
			        cp_ratio >= 0.51 && cp_ratio <= 0.70 && lp_ratio >= 0.31 && lp_ratio <= 0.50 && passivo_ratio = "entre 1% e 20%", 7,
			        cp_ratio >= 0.71 && cp_ratio <= 1 && lp_ratio >= 0 && lp_ratio <= 0.29 && passivo_ratio = "entre 1% e 20%", 8,
			        cp_ratio <= 0.20 && lp_ratio >= 0.80 && passivo_ratio = "entre 21% e 50%", 9,
			        cp_ratio >= 0.21 && cp_ratio <= 0.50 && lp_ratio >= 0.50 && lp_ratio <= 0.79 && passivo_ratio = "entre 21% e 50%", 10,
			        cp_ratio >= 0.51 && cp_ratio <= 0.70 && lp_ratio >= 0.31 && lp_ratio <= 0.50 && passivo_ratio = "entre 21% e 50%", 11,
			        cp_ratio >= 0.71 && cp_ratio <= 1 && lp_ratio >= 0 && lp_ratio <= 0.29 && passivo_ratio = "entre 21% e 50%", 12,
			        cp_ratio <= 0.20 && lp_ratio >= 0.80 && passivo_ratio = "entre 51% e 70%", 13,
			        cp_ratio >= 0.21 && cp_ratio <= 0.50 && lp_ratio >= 0.50 && lp_ratio <= 0.79 && passivo_ratio = "entre 51% e 70%", 14,
			        cp_ratio >= 0.51 && cp_ratio <= 0.70 && lp_ratio >= 0.31 && lp_ratio <= 0.50 && passivo_ratio = "entre 51% e 70%", 15,
			        cp_ratio >= 0.71 && cp_ratio <= 1 && lp_ratio >= 0 && lp_ratio <= 0.29 && passivo_ratio = "entre 51% e 70%", 16,
			        cp_ratio <= 0.20 && lp_ratio >= 0.80 && passivo_ratio = "entre 71% e 100%", 17,
			        cp_ratio >= 0.21 && cp_ratio <= 0.50 && lp_ratio >= 0.50 && lp_ratio <= 0.79 && passivo_ratio = "entre 71% e 100%", 18,
			        cp_ratio >= 0.51 && cp_ratio <= 0.70 && lp_ratio >= 0.31 && lp_ratio <= 0.50 && passivo_ratio = "entre 71% e 100%", 19,
			        cp_ratio >= 0.71 && cp_ratio <= 1 && lp_ratio >= 0 && lp_ratio <= 0.29 && passivo_ratio = "entre 71% e 100%", 20,
			        BLANK()
			    )
			
			VAR saldoInterpretacao = 
			    SWITCH(
			        cenario,
			        1, "O cenário indica que a empresa tem uma baixa dependência de financiamentos de curto prazo, o que é positivo para a saúde financeira. Com 100% dos empréstimos no passivo circulante representando apenas <strong style='color: #000000;'>" & FORMAT(proporcao_passivo, "0.0%") & "</strong> do total do passivo <strong style='color: #000000;'>" & FORMAT([totpassivo II], "R$ #,##0,00") & "</strong>, a empresa possui um risco reduzido de liquidez.",
			        2, "A dependência moderada de empréstimos de curto prazo sugere que a empresa utiliza esses recursos de forma estratégica para cobrir necessidades operacionais. No entanto, isso também aumenta a necessidade de uma gestão cuidadosa do fluxo de caixa.",
			        3, " A alta dependência de empréstimos de curto prazo, representando <strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong> do passivo total <strong style='color: #000000;'>" & FORMAT([totpassivo II], "R$ #,##0,00") & "</strong>, coloca a empresa em uma posição de maior risco financeiro devido à necessidade frequente de refinanciamento.",
			        4, "A dependência crítica de empréstimos de curto prazo, com <strong style='color: #000000;'>" & FORMAT(proporcao_passivo, "0.0%") & "</strong> do passivo, indica uma vulnerabilidade financeira muito alta. A empresa está exposta a riscos significativos de liquidez e refinanciamento. ",
			        5, "A empresa mantém um baixo nível de dívida total <strong style='color: #000000;'>" & FORMAT(proporcao_passivo, "0.0%") & "</strong>, com uma pequena porção em curto prazo e a maioria em longo prazo, o que indica uma gestão financeira conservadora e uma posição de baixa vulnerabilidade. ",
			        6, "A estrutura de dívida equilibrada entre curto e longo prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong> no curto prazo e <strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong> no longo prazo), com baixo impacto no passivo total, sugere uma abordagem prudente e bem balanceada na gestão financeira da empresa. ",
			        7, " A maior proporção de dívida de curto prazo, embora ainda com baixo impacto no passivo total, pode indicar uma necessidade de maior atenção ao gerenciamento do fluxo de caixa para evitar problemas de liquidez. ",
			        8, " Alta dependência de curto prazo, com <strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong> do total de empréstimos, mas com um impacto geral baixo, os emprestimos representam <strong style='color: #000000;'>" & FORMAT(proporcao_passivo, "0.0%") & "</strong> do passivo apenas, no entanto, isso requer uma gestão cuidadosa para evitar vulnerabilidades financeiras. A empresa precisa monitorar de perto sua capacidade de cumprir obrigações a curto prazo. ",
			        9, "Com uma baixa proporção de dívida de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) e uma dependência maior de longo prazo (<strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong>), a empresa se beneficia de uma estrutura financeira mais estável, com os empréstimos representando <strong style='color: #000000;'>" & FORMAT(proporcao_passivo, "0.0%") & "</strong> do passivo. ",
			        10, "A combinação de uma dívida moderada de curto prazo e uma maior proporção de longo prazo indica uma estrutura equilibrada de passivos, embora seja importante manter uma vigilância contínua sobre os níveis de endividamento e sua relação com o passivo total <strong style='color: #000000;'>" & FORMAT([totpassivo II], "R$ #,##0,00") & "</strong>. ",
			        11, "A proporção equilibrada de curto prazo (entre <strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) e longo prazo (entre <strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong>) sugere uma estratégia financeira balanceada, com a dívida representando uma parte significativa do passivo total <strong style='color: #000000;'>" & FORMAT(proporcao_passivo, "0.0%") & "</strong>. ",
			        12, "A dependência mais alta de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) exige atenção ao gerenciamento do fluxo de caixa para evitar pressões financeiras, especialmente com a dívida representando <strong style='color: #000000;'>" & FORMAT(proporcao_passivo, "0.0%") & "</strong> do passivo total. ",
			        13, "A baixa dependência de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) com uma alta proporção de longo prazo (<strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong>) proporciona uma base financeira estável, com os empréstimos representando <strong style='color: #000000;'>" & FORMAT(proporcao_passivo, "0.0%") & "</strong> do passivo total. ",
			        14, "A combinação de uma dívida moderada de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) e uma maior proporção de longo prazo (<strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong>) indica uma estrutura equilibrada de passivos. ",
			        15, "A proporção equilibrada de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) e longo prazo (<strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong>) sugere uma abordagem financeira balanceada, com a dívida representando uma parte significativa do passivo total. ",
			        16, "A dependência mais alta de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) exige atenção ao gerenciamento do fluxo de caixa para evitar pressões financeiras, especialmente com a dívida representando uma parte significativa do passivo total. ",
			        17, "A baixa dependência de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) com uma alta proporção de longo prazo (<strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong>) proporciona uma base financeira estável, com os empréstimos representando uma parte substancial do passivo total. ",
			        18, "A combinação de uma dívida moderada de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) e uma maior proporção de longo prazo (<strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong>) indica uma estrutura equilibrada de passivos. ",
			        19, "A proporção equilibrada de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) e longo prazo (<strong style='color: #000000;'>" & FORMAT(lp_ratio, "0.0%") & "</strong>) sugere uma abordagem financeira balanceada, com a dívida representando uma parte significativa do passivo total. ",
			        20, "A dependência mais alta de curto prazo (<strong style='color: #000000;'>" & FORMAT(cp_ratio, "0.0%") & "</strong>) exige atenção ao gerenciamento do fluxo de caixa para evitar pressões financeiras, especialmente com a dívida representando uma parte significativa do passivo total. ",
			        BLANK()
			    )
			VAR saldoCurtoPrazo = 
			    SWITCH(
			        cenario,
			        1, "Continuar a manter essa baixa dependência de financiamentos de curto prazo é essencial. A empresa deve focar em manter reservas de caixa adequadas para enfrentar qualquer necessidade de liquidez inesperada e garantir que os pagamentos possam ser realizados sem dificuldades.",
			        2, "Avaliar a possibilidade de renegociar os prazos de parte dos empréstimos para alongar a dívida pode reduzir a pressão sobre o fluxo de caixa e proporcionar mais estabilidade financeira. ",
			        3, "Refinanciar parte da dívida em condições mais favoráveis é crucial para reduzir os custos financeiros e aliviar a pressão sobre o fluxo de caixa a curto prazo. Negociar taxas de juros mais baixas e prazos mais longos pode ser benéfico.",
			        4, "Priorizar a redução da dívida de curto prazo deve ser uma meta imediata. Renegociar prazos e buscar alternativas de financiamento mais sustentáveis são passos essenciais para aliviar a pressão sobre a empresa.",
			        5, "Aproveitar o baixo nível de endividamento para investir em oportunidades estratégicas que possam gerar retornos significativos. A empresa pode explorar investimentos em inovação, expansão de mercado ou aquisição de ativos estratégicos.",
			        6, "Manter essa estrutura de dívida equilibrada para minimizar riscos e custos de capital. Avaliar continuamente o desempenho operacional e financeiro para assegurar que a empresa permaneça em uma posição estável.",
			        7, "Refinanciar parte da dívida de curto prazo para reduzir a pressão sobre o fluxo de caixa é importante. Negociar melhores condições de pagamento com fornecedores e clientes também pode ajudar a melhorar a gestão de caixa.",
			        8, "Implementar estratégias para alongar os prazos das dívidas e reduzir a dependência de curto prazo. Renegociar condições de empréstimos e explorar opções de financiamento alternativas pode aliviar a pressão sobre o caixa.",
			        9, "Explorar oportunidades de financiamento de curto prazo mais barato pode reduzir os custos financeiros e liberar recursos para outras áreas. Avaliar constantemente as condições do mercado para aproveitar oportunidades vantajosas. ",
			        10, "Avaliar constantemente o custo do capital e buscar oportunidades para reduzir os custos financeiros. Manter uma reserva de caixa adequada para cobrir necessidades emergenciais. ",
			        11, "Refinanciar dívidas de curto prazo para longo prazo é essencial para reduzir o risco de liquidez. Negociar melhores condições com credores pode proporcionar mais estabilidade financeira.",
			        12, "Refinanciar e reduzir a dívida de curto prazo deve ser uma prioridade urgente. Negociar condições mais favoráveis e alongar prazos pode ajudar a aliviar a pressão sobre o caixa.",
			        13, "Priorizar a redução da dívida de longo prazo pode ajudar a reduzir os custos financeiros e melhorar a flexibilidade financeira da empresa. Avaliar a possibilidade de amortização antecipada de dívidas com taxas de juros elevadas. ",
			        14, "Refinanciar parte das dívidas para equilibrar os prazos e reduzir os custos financeiros. Negociar condições mais favoráveis com credores para melhorar a estrutura de dívida. ",
			        15, "Alongar os prazos de dívida é uma necessidade urgente para reduzir a pressão sobre o fluxo de caixa. Negociar com credores para obter melhores condições é crucial.",
			        16, "Priorizar a renegociação de prazos e redução da dívida de curto prazo é essencial para evitar problemas de liquidez. Explorar opções de financiamento de longo prazo pode proporcionar mais estabilidade. ",
			        17, "Estruturar financiamento para alongar prazos e reduzir a alavancagem pode ajudar a melhorar a posição financeira. Negociar melhores condições com credores também é importante.",
			        18, " Refinanciar dívidas para reduzir custos e prazos é essencial. Negociar condições mais favoráveis pode ajudar a aliviar a pressão sobre o fluxo de caixa e proporcionar mais estabilidade. ",
			        19, "Focar na renegociação para alongar prazos de empréstimos é essencial para reduzir a pressão sobre o fluxo de caixa e melhorar a estabilidade financeira. Avaliar todas as opções de refinanciamento disponíveis.",
			        20, "Realocar urgentemente a dívida de curto prazo para longo prazo é vital para reduzir a pressão sobre o fluxo de caixa. Negociar melhores condições de financiamento com credores deve ser uma prioridade imediata.",
			        "Estratégia de curto prazo não disponível."
			    )
			VAR saldoLongoPrazo = 
			    SWITCH(
			        cenario,
			         1, "Considerar alternativas de financiamento de longo prazo, como debêntures ou empréstimos bancários com prazos mais longos, pode ajudar a garantir que a empresa esteja preparada para projetos de capital e investimentos futuros, sem comprometer a liquidez.",
			        2, "Monitorar rigorosamente o fluxo de caixa e implementar um sistema robusto de previsões financeiras pode ajudar a identificar e mitigar riscos de liquidez. Além disso, diversificar as fontes de financiamento pode aumentar a resiliência financeira da empresa.",
			        3, "Implementar medidas de controle de custos rigorosas e aumentar a eficiência operacional são fundamentais para melhorar a lucratividade e a capacidade de pagamento da empresa. Investir em automação e otimização de processos pode gerar economias significativas.",
			        4, "Reavaliar a estrutura de capital é necessário para assegurar a estabilidade financeira a longo prazo. A empresa deve considerar buscar novas fontes de financiamento de longo prazo, como emissão de ações ou financiamento bancário com prazos mais estendidos.",
			        5, "Continuar monitorando o custo do capital e as condições do mercado para otimizar o mix de financiamento. Manter a flexibilidade financeira permitirá à empresa se adaptar rapidamente a mudanças no ambiente econômico.",
			        6, "Focar no crescimento e expansão utilizando o financiamento disponível de forma estratégica. Investir em projetos que ofereçam retornos sustentáveis e que possam fortalecer a posição competitiva da empresa no mercado.",
			        7, " Investir em projetos com retorno rápido pode melhorar a liquidez e proporcionar uma base financeira mais sólida para a empresa. Focar em aumentar a eficiência operacional e reduzir custos desnecessários também será benéfico.",
			        8, " Adotar estratégias para aumentar o financiamento de longo prazo, como emissão de títulos ou obtenção de linhas de crédito mais extensas, ajudará a melhorar a gestão do capital de giro e evitar problemas de liquidez.",
			        9, "Manter a estrutura atual de financiamento de longo prazo para minimizar riscos de refinanciamento. Focar em otimizar operações para melhorar a geração de caixa e manter a saúde financeira robusta.",
			        10, "Monitorar a estrutura de capital e ajustar conforme necessário para manter o equilíbrio entre curto e longo prazo. Investir em melhorias operacionais pode gerar mais caixa e reduzir a dívida ao longo do tempo.",
			        11, "Melhorar a gestão de recebíveis e estoques pode liberar caixa adicional e fortalecer a posição financeira da empresa. Implementar práticas de gestão de capital de giro eficientes será benéfico a longo prazo.",
			        12, "Implementar medidas para melhorar a geração de caixa, como aumentar a eficiência operacional e controlar custos, ajudará a empresa a fortalecer sua posição financeira e reduzir a dependência de empréstimos de curto prazo.",
			        13, " Avaliar a estrutura de capital e buscar alternativas de financiamento que ofereçam melhores condições. Considerar a emissão de ações ou outras formas de capital próprio para reduzir a alavancagem e fortalecer a base de capital.",
			        14, "Melhorar a eficiência operacional para aumentar a capacidade de pagamento e reduzir a dependência de financiamentos externos. Investir em tecnologias e processos que aumentem a produtividade e gerem economias de custo.",
			        15, "Implementar uma gestão de custos rigorosa para melhorar a lucratividade e liberar recursos para pagamento de dívidas. Avaliar oportunidades de desinvestimento em ativos não essenciais para fortalecer a posição financeira.",
			        16, "Melhorar a eficiência do capital de giro e implementar práticas robustas de gestão financeira são cruciais para garantir a sustentabilidade a longo prazo. Avaliar a estrutura de capital e considerar a diversificação das fontes de financiamento.",
			        17, "Otimizar operações para aumentar a geração de caixa e reduzir a dependência de financiamentos externos. Investir em melhorias operacionais e inovação pode fortalecer a posição competitiva da empresa e proporcionar uma base financeira mais sólida.",
			        18, "Investir em melhorias operacionais para gerar caixa adicional e reduzir a alavancagem. Focar na eficiência e na otimização de processos pode proporcionar economias significativas e fortalecer a posição financeira da empresa.",
			        19, "Implementar uma estratégia agressiva de redução de custos e aumento da eficiência operacional é crucial para melhorar a lucratividade e a capacidade de pagamento. Investir em tecnologias que aumentem a produtividade e reduzam os custos operacionais pode gerar economias significativas.",
			        20, "Revisar a estrutura de capital da empresa para reduzir a vulnerabilidade financeira. Implementar uma estratégia de desinvestimento em ativos não essenciais pode liberar recursos para reduzir a dívida e fortalecer a posição financeira da empresa.",
			        "Estratégia de longo prazo não disponível."
			    )
			
			    //MOVIMENTAÇÃO
			
			    VAR cp_variacao = DIVIDE([variacao_emprest_CP] + [variacao_emprest_LP], [ssomaemprestEfinan])
			
			VAR var_emprest =
			    SWITCH(
			        TRUE(),
			        cp_variacao >= 0.71, "8",
			        cp_variacao >= 0.61, "7",
			        cp_variacao >= 0.51, "6",
			        cp_variacao >= 0.41, "5",
			        cp_variacao >= 0.31, "4",
			        cp_variacao >= 0.21, "3",
			        cp_variacao >= 0.11, "2",
			        cp_variacao >= 0, "1",
			        cp_variacao >= -0.10, "9",
			        cp_variacao >= -0.20, "10",
			        cp_variacao >= -0.30, "11",
			        cp_variacao >= -0.40, "12",
			        cp_variacao >= -0.50, "13",
			        cp_variacao >= -0.60, "14",
			        cp_variacao >= -0.70, "15",
			        "16"
			    )
			
			VAR interpret_var_comentario =
			    SWITCH(
			        var_emprest,
			        "8", "Aumento crítico, indicando uma dependência extrema de empréstimos.",
			        "7", "Aumento muito alto, o que pode ser preocupante.",
			        "6", "Aumento expressivo, possivelmente indicando problemas de liquidez.",
			        "5", "Aumento substancial no saldo de empréstimos.",
			        "4", "Aumento significativo, sugerindo a realização de grandes projetos ou cobertura de grandes déficits.",
			        "3", "Considerável aumento no saldo de empréstimos.",
			        "2", "Aumento moderado nos empréstimos, indicando maior necessidade de capital.",
			        "1", "Pequeno aumento no saldo de empréstimos.",
			        "9", "Redução pequena nos empréstimos.",
			        "10", "Redução moderada nos empréstimos.",
			        "11", "Considerável redução, melhorando significativamente a alavancagem.",
			        "12", "Redução significativa nos empréstimos.",
			        "13", "Redução substancial, melhorando a posição financeira.",
			        "14", "Redução expressiva na dívida.",
			        "15", "Grande redução, indicando uma melhoria substancial na saúde financeira.",
			        "16", "Redução crítica, possivelmente eliminando a maioria ou toda a dívida."
			    )
			
			RETURN
			"<div style='font-family: Bw Glenn Sans DEMO Medium, sans-serif; margin: 20px;'>
			    <h1 style='color: #000000; font-family: Brush Script MT, cursive; font-style: italic;'>Nossas Considerações</h1>
			    <h3 style='font-weight: bold;'>🔍 Análise do Saldo</h3>
