	measure solvencia = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			(
			    0.05 * 'Medidas_balancetenew'[rentabilidade cpt] +
			    1.65 * 'Medidas_balancetenew'[lliquidez geral] +
			    3.55 * 'Medidas_balancetenew'[lliquidez seca] -
			    1.06 * 'Medidas_balancetenew'[lliquidez corrente] -
			    0.33 * 'Medidas_balancetenew'[Endividamento total]
			),
			dCalendario[data] = UltimoMesTrimestre
			)
			
			```
		lineageTag: 9a5dc4b2-c385-4786-9277-0610e6bef384

