	measure DDespesaControladas_actual_month = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_controladas"),
			        balancetenew[vlr]
			    ),
			    LASTNONBLANK(
			        FILTER(
			            ALL(dCalendario[data]),
			            dCalendario[data] <= MAX(dCalendario[data])
			        ),
			        CALCULATE(
			            SUMX(
			                FILTER(
			                    balancetenew,
			                    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_controladas"),
			                balancetenew[vlr]
			            )
			        )
			    ),
			    dCalendario[data] = UltimoMesTrimestre
			)
			
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: eefbf06b-51e5-465f-8034-407b56ab5132

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

