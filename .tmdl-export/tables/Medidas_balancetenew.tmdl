	measure variacao%_switch_roic_ = ```
			
			VAR nopat_ = CALCULATE(
			    [LLucro_liquido] - [receita_financeira] + [despesa_financeira] + [desp_nao_operacionais]
			    )
			VAR nopat_LY = CALCULATE(
			    [LLucro_liquido] - [receita_financeira] + [despesa_financeira] + [desp_nao_operacionais],
			    DATEADD(dCalendario[data], -1, YEAR)
			)
			VAR nopat_variacao =
			DIVIDE(
			    nopat_ - nopat_LY,
			    nopat_LY
			)
			VAR roic_ = 
			    DIVIDE(
			        nopat_,
			        [patrimonioLiq]
			    )
			VAR roic_LY = 
			    DIVIDE(
			        nopat_LY,
			        CALCULATE(
			        [patrimonioLiq],
			        DATEADD(dCalendario[data],
			        -1,
			        YEAR
			        )
			    ))
			VAR roic_variacao =
			FORMAT(
			    roic_ - roic_LY, 
			    "0.00%"
			    )
			VAR receita_financeira_LY =
			CALCULATE(
			    [receita_financeira], 
			    DATEADD(
			        dCalendario[data], 
			        -1, 
			        YEAR
			    )
			)
			VAR despesa_financeira_LY =
			CALCULATE(
			    [despesa_financeira], 
			    DATEADD(
			        dCalendario[data], 
			        -1, 
			        YEAR
			    )
			)
			VAR desp_n_operacional_LY =
			CALCULATE(
			    [desp_nao_operacionais], 
			    DATEADD(
			        dCalendario[data], 
			        -1, 
			        YEAR
			    )
			)
			VAR patrimonio_liq_LY =
			CALCULATE(
			    [patrimonioLiq], 
			    DATEADD(
			        dCalendario[data], 
			        -1, 
			        YEAR
			    )
			)
			RETURN
			SWITCH(
			    SELECTEDVALUE(
			        D_ROIC[nome]
			    ),
			    "(=) Lucro ou Prejuízo Líquido", FORMAT([variacao%_lucro_liq_YoY], "0.00%"),
			    "(-) Receita Financeira", FORMAT(DIVIDE([receita_financeira] - receita_financeira_LY, receita_financeira_LY ), "0.00%"),
			    "(+) Despesa Financeira", FORMAT(DIVIDE([despesa_financeira] - despesa_financeira_LY, despesa_financeira_LY), "0.00%"),
			    "(+/-) Despesas não Operacionais", FORMAT(DIVIDE([desp_nao_operacionais] - desp_n_operacional_LY, desp_n_operacional_LY), "0.00%"),
			    "CAPITAL INVESTIDO (PL + Capital de Terceiros)", FORMAT(DIVIDE([patrimonioLiq] - patrimonio_liq_LY, patrimonio_liq_LY), "0.00%"),
			    "ROIC", roic_variacao,
			    "(=) NOPAT", FORMAT(nopat_variacao, "0.00%")
			
			)
			```
		lineageTag: 063a798b-7e33-4c73-973a-94134990def6

	measure variacao%_lucro_liq_YoY = ```
			
			VAR lucro_liq_LY_ =
			[Lucro_liquido_LY]
			RETURN  
			
			DIVIDE(
			    [LLucro_liquido] 
			    - lucro_liq_LY_,
			    lucro_liq_LY_
			)
			```
		formatString: #,0.00%;-#,0.00%;#,0.00%
		lineageTag: db629e63-94a3-48ef-bc76-1cc2fe8d3a69

