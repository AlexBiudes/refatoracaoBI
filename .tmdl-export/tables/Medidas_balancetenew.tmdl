	measure 'Timeline Ciclo Operacional HTML' =
			
			VAR PMR_  = COALESCE([Prazo Médio Contas a Receber], 0)
			VAR PMGE_ = COALESCE([prazo_medio_giro_estoque_aging], 0)
			
			VAR DiaEntrada      = 0
			VAR DiaEstoque      = PMGE_
			VAR DiaPagamentos   = 0
			VAR DiaRecebimentos = PMGE_ + PMR_
			
			VAR DiasRecebimento = DiaRecebimentos - DiaEstoque
			
			VAR MaxDia =
			    MAX(
			        1,
			        MAX(
			            DiaEstoque,
			            MAX(DiaPagamentos, DiaRecebimentos)
			        )
			    )
			
			VAR PctEntradaNum      = DIVIDE(DiaEntrada, MaxDia, 0) * 100
			VAR PctEstoqueNum      = DIVIDE(DiaEstoque, MaxDia, 0) * 100
			VAR PctPagamentosNum   = DIVIDE(DiaPagamentos, MaxDia, 0) * 100
			VAR PctRecebimentosNum = DIVIDE(DiaRecebimentos, MaxDia, 0) * 100
			
			-- agora a faixa fica entre PMGE e PMR
			VAR PctCGIniNum  = MIN(PctEstoqueNum, PctRecebimentosNum)
			VAR PctCGFimNum  = MAX(PctEstoqueNum, PctRecebimentosNum)
			VAR PctCGLargNum = PctCGFimNum - PctCGIniNum
			
			VAR PctEntrada      = SUBSTITUTE(FORMAT(PctEntradaNum, "0.0"), ",", ".")
			VAR PctEstoque      = SUBSTITUTE(FORMAT(PctEstoqueNum, "0.0"), ",", ".")
			VAR PctPagamentos   = SUBSTITUTE(FORMAT(PctPagamentosNum, "0.0"), ",", ".")
			VAR PctRecebimentos = SUBSTITUTE(FORMAT(PctRecebimentosNum, "0.0"), ",", ".")
			VAR PctCGIni        = SUBSTITUTE(FORMAT(PctCGIniNum, "0.0"), ",", ".")
			VAR PctCGLarg       = SUBSTITUTE(FORMAT(PctCGLargNum, "0.0"), ",", ".")
			
			VAR CorCapitalGiro =
			    IF(DiasRecebimento < 0, "#D64545", "#2D9CDB")
			
			RETURN
			"
			<div style='
			    font-family:Segoe UI, Arial, sans-serif;
			    background:#ffffff;
			    border:1px solid #E6EAF0;
			    border-radius:8px;
			    padding:18px 20px 18px 20px;
			    box-sizing:border-box;
			    width:100%;
			    color:#23384D;
			    overflow:hidden;
			'>
			
			    <div style='font-size:15px; font-weight:600; color:#26435C; margin-bottom:10px;'>
			        Timeline do Ciclo Operacional
			    </div>
			
			    <div style='font-size:11px; font-weight:600; color:#6B7A8C; margin-bottom:18px;'>
			        Este Período
			    </div>
			
			    <div style='
			        display:flex;
			        align-items:center;
			        justify-content:space-between;
			        gap:36px;
			        flex-wrap:nowrap;
			        width:100%;
			    '>
			
			        <div style='
			            flex:1 1 auto;
			            min-width:0;
			            width:100%;
			        '>
			            <div style='position:relative; height:132px; width:100%;'>
			
			                <!-- linha base -->
			                <div style='
			                    position:absolute;
			                    left:0;
			                    right:0;
			                    top:58px;
			                    height:3px;
			                    background:#BFC9D4;
			                    border-radius:999px;
			                '></div>
			
			                <!-- seta -->
			                <div style='
			                    position:absolute;
			                    right:-1px;
			                    top:54px;
			                    width:0;
			                    height:0;
			                    border-top:5px solid transparent;
			                    border-bottom:5px solid transparent;
			                    border-left:12px solid #BFC9D4;
			                '></div>
			
			                <!-- faixa entre PMGE e PMR -->
			                <div style='
			                    position:absolute;
			                    left:" & PctCGIni & "%;
			                    width:" & PctCGLarg & "%;
			                    top:57px;
			                    height:4px;
			                    background:" & CorCapitalGiro & ";
			                    border-radius:999px;
			                '></div>
			
			                <!-- Entrada -->
			                <div style='position:absolute; left:calc(" & PctEntrada & "% - 3px); top:34px;'>
			                    <div style='width:6px; height:28px; background:#2F80ED; border-radius:999px;'></div>
			                </div>
			                <div style='
			                    position:absolute;
			                    left:" & PctEntrada & "%;
