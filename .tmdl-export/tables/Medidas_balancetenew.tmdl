	measure resultado_financeiro_actual_month = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			RETURN
			ROUND(
			CALCULATE(
			    SUMX(
			        VALUES(dCalendario[data]),
			        Medidas_balancetenew[receita_financeira] + Medidas_balancetenew[despesa_financeira]
			    ),
			    dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre), 0)
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 7838f85d-8fa0-41f4-a8f4-2be5c475f16c

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure narrativa_emprestimos = ```
			
			
			VAR ContaAtual = [Emprestimos_CP]
			VAR TotalMov = [Emprestimos_CP] - [emprestimos_CP_LM]
			VAR MediaMov = [Emprestimos_CP] - [emprestimos_CP_LM]
			VAR MinMov = [Emprestimos_CP]
			VAR MaxMov = [Emprestimos_CP]
			VAR MaiorMovValor = "ESCOLHER MEDIDA"
			VAR MaiorMovData = "ESCOLHER MEDIDA"
			VAR EntradaTotal = "ESCOLHER MEDIDA"
			VAR SaidaTotal = "ESCOLHER MEDIDA"
			
			RETURN
			"<div style='font-family: Arial, sans-serif; margin: 20px;'>
			    <h2 style='color: #2E86C1; border-bottom: 2px solid #2E86C1; padding-bottom: 5px;'>Resumo da Conta " & ContaAtual & "</h2>
			    <p>A conta <strong style='color: #E74C3C;'>" & ContaAtual & "</strong> teve um total de movimentações de <strong style='color: #E74C3C;'>" & TotalMov & "</strong>.</p>
			    <p>O maior movimento foi de <strong style='color: #E74C3C;'>" & MaiorMovValor & "</strong> na data <strong style='color: #E74C3C;'>" & MaiorMovData & "</strong>.</p>
			    <p>A média dos movimentos foi de <strong style='color: #E74C3C;'>" & FORMAT(MediaMov, "0.00") & "</strong>, com um mínimo de <strong style='color: #E74C3C;'>" & MinMov & "</strong> e um máximo de <strong style='color: #E74C3C;'>" & MaxMov & "</strong>.</p>
			    <p>No período, a conta teve um total de entradas de <strong style='color: #E74C3C;'>" & EntradaTotal & "</strong> e saídas de <strong style='color: #E74C3C;'>" & SaidaTotal & "</strong>.</p>
			</div>"
			
			```
		lineageTag: 228e2d6e-d014-462f-9a60-93cbab041e97

	measure narrativa_JurosPagosEmprest = ```
			
			VAR ValorJurosPagos = [TotalJuros]
			VAR ValorJurosPagosLM = CALCULATE([TotalJuros], DATEADD(dCalendario[data], -1, MONTH))
			VAR TendenciaJurosPagos = IF(ValorJurosPagos > ValorJurosPagosLM, "um aumento", "uma diminuição")
			RETURN
			"O total de juros pagos durante " & [periodo_atual] &  " foi de " & FORMAT(ValorJurosPagos, "R$ #,##0.00") & ". Isso representa " & TendenciaJurosPagos & " em comparação com " & [periodo_anterior] & ", indicando " & IF(TendenciaJurosPagos ="um aumento", "um desgate na saúde financeira da empresa", "uma melhora na saúde financeira da empresa")
			
			```
		lineageTag: 541be134-4fd2-46bd-b60d-8394cb4744ad

