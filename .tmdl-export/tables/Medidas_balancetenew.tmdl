	measure atvcircu|totAtivo = ```
			
			VAR selected_date = CALCULATE(
			                    MAX('balancetenew'[data]), 
			                    ALLSELECTED('balancetenew'[data])
			                  )
			RETURN
			    DIVIDE(
			        SUMX(
			            FILTER('balancetenew', 
			                'balancetenew'[data] = selected_date
			            ),
			            'Medidas_balancetenew'[SomaAtivCircu]
			        ),
			        SUMX(
			            FILTER('balancetenew', 
			                'balancetenew'[data] = selected_date
			            ),
			            'Medidas_balancetenew'[totativo]
			        )
			    )
			
