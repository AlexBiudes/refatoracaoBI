		annotation PBI_FormatHint = {"isDecimal":true}

	measure %DDespControladas_atual|anterior_MC = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
