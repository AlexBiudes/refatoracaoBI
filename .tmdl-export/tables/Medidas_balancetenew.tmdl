	measure var_outras_despesas_ACU = ```
			
			
			VAR vdespesas =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_tributarias" || 
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_despesas_operacionais"
			        ),
			        balancetenew[vlr]
			    ),
			    DATESYTD(dCalendario[data])
			)
			
			VAR vdespesas_ly =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_tributarias" || 
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_despesas_operacionais"
			        ),
			        balancetenew[vlr]
			    ),
			    DATESYTD(DATEADD(dCalendario[data], -1, YEAR))
			)
			
			VAR vvariacao =
			DIVIDE(
			vdespesas - vdespesas_ly,
			vdespesas_ly)
			
			
			RETURN
			vvariacao
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e8fa2fb8-2f7c-47c3-9856-7a9d68f51dcf

