			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    font-weight:600;
			                    white-space:nowrap;
			                '>
			                    Dia " & FORMAT(DiaPagamentos, "0") & "
			                </div>
			                <div style='display:none;
			                    position:absolute;
			                    left:" & PctPagamentos & "%;
			                    top:74px;
			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    text-align:center;
			                    width:96px;
			                    line-height:1.25;
			                '>
			                    Fornecedores<br/>Pagos
			                </div>
			
			                <!-- Recebimentos -->
			                <div style='position:absolute; left:calc(" & PctRecebimentos & "% - 3px); top:34px;'>
			                    <div style='width:6px; height:28px; background:#34A853; border-radius:999px;'></div>
			                </div>
			                <div style='
