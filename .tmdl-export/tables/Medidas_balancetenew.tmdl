			'>
			
			    <div style='font-size:15px; font-weight:600; color:#26435C; margin-bottom:10px;'>
			        Timeline do Capital de Giro
			    </div>
			
			    <div style='font-size:11px; font-weight:600; color:#6B7A8C; margin-bottom:18px;'>
			        Este período
			    </div>
			
			    <div style='
			        display:flex;
			        align-items:center;
			        justify-content:space-between;
			        gap:36px;
			        flex-wrap:nowrap;
			        width:100%;
			    '>
			
			        <div style='
			            flex:1 1 auto;
			            min-width:0;
			            width:100%;
			        '>
			            <div style='position:relative; height:132px; width:100%;'>
			
			                <!-- linha base -->
			                <div style='
			                    position:absolute;
			                    left:0;
			                    right:0;
			                    top:58px;
			                    height:3px;
			                    background:#BFC9D4;
			                    border-radius:999px;
			                '></div>
			
			                <!-- seta -->
			                <div style='
			                    position:absolute;
			                    right:-1px;
			                    top:54px;
			                    width:0;
			                    height:0;
			                    border-top:5px solid transparent;
			                    border-bottom:5px solid transparent;
			                    border-left:12px solid #BFC9D4;
			                '></div>
			
			                <!-- faixa entre PMGE e PMR -->
			                <div style='
			                    position:absolute;
			                    left:" & PctCGIni & "%;
			                    width:" & PctCGLarg & "%;
			                    top:57px;
			                    height:4px;
			                    background:" & CorCapitalGiro & ";
			                    border-radius:999px;
			                '></div>
			
			                <!-- Entrada -->
			                <div style='position:absolute; left:calc(" & PctEntrada & "% - 3px); top:34px;'>
			                    <div style='width:6px; height:28px; background:#2F80ED; border-radius:999px;'></div>
			                </div>
			                <div style='
			                    position:absolute;
			                    left:" & PctEntrada & "%;
			                    top:6px;
			                    transform:translateX(-8%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    font-weight:600;
			                    white-space:nowrap;
			                '>
			                    Dia 0
			                </div>
			                <div style='
			                    position:absolute;
			                    left:" & PctEntrada & "%;
			                    top:74px;
			                    transform:translateX(-8%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    text-align:left;
			                    width:88px;
			                    line-height:1.25;
			                '>
			                    Entradas nos<br/>Estoques
			                </div>
			
			                <!-- Estoque vendido -->
			                <div style='position:absolute; left:calc(" & PctEstoque & "% - 3px); top:34px;'>
			                    <div style='width:6px; height:28px; background:#F2994A; border-radius:999px;'></div>
			                </div>
			                <div style='
			                    position:absolute;
			                    left:" & PctEstoque & "%;
			                    top:6px;
			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    font-weight:600;
			                    white-space:nowrap;
			                '>
			                    Dia " & FORMAT(DiaEstoque, "0") & "
			                </div>
			                <div style='
			                    position:absolute;
			                    left:" & PctEstoque & "%;
			                    top:74px;
			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    text-align:center;
			                    width:86px;
			                    line-height:1.25;
			                '>
			                    Estoque<br/>Vendido
			                </div>
			
			                <!-- marco ocultado para não embolar no início -->
			                <div style='display:none; position:absolute; left:calc(" & PctPagamentos & "% - 3px); top:34px;'>
			                    <div style='width:6px; height:28px; background:#BB4C97; border-radius:999px;'></div>
			                </div>
			                <div style='display:none;
			                    position:absolute;
			                    left:" & PctPagamentos & "%;
			                    top:6px;
			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    font-weight:600;
			                    white-space:nowrap;
			                '>
			                    Dia " & FORMAT(DiaPagamentos, "0") & "
			                </div>
			                <div style='display:none;
			                    position:absolute;
			                    left:" & PctPagamentos & "%;
			                    top:74px;
			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    text-align:center;
			                    width:96px;
			                    line-height:1.25;
			                '>
			                    Fornecedores<br/>Pagos
			                </div>
			
			                <!-- Recebimentos -->
			                <div style='position:absolute; left:calc(" & PctRecebimentos & "% - 3px); top:34px;'>
			                    <div style='width:6px; height:28px; background:#34A853; border-radius:999px;'></div>
			                </div>
			                <div style='
			                    position:absolute;
			                    left:" & PctRecebimentos & "%;
			                    top:6px;
			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    font-weight:600;
			                    white-space:nowrap;
			                '>
			                    Dia " & FORMAT(DiaRecebimentos, "0") & "
			                </div>
			                <div style='
			                    position:absolute;
			                    left:" & PctRecebimentos & "%;
			                    top:74px;
			                    transform:translateX(-50%);
			                    font-size:10px;
			                    color:#6B7A8C;
			                    text-align:center;
			                    width:84px;
			                    line-height:1.25;
			                '>
			                    Recebimentos
			                </div>
			
			            </div>
			        </div>
			
			        <div style='
			            flex:0 0 132px;
			            width:132px;
			            min-width:132px;
			            max-width:132px;
			            background:#0F8FA6;
			            color:#ffffff;
			            border-radius:8px;
			            padding:18px 12px;
			            text-align:center;
			            box-sizing:border-box;
			            margin-left:8px;
			        '>
			            <div style='font-size:32px; font-weight:700; line-height:1; margin-bottom:10px;'>
			                " & FORMAT(DiasRecebimento, "0") & "
			            </div>
			            <div style='font-size:12px; line-height:1.25;'>
			                Dias para<br/>Recebimento
			            </div>
			        </div>
			
			    </div>
			</div>
			"
		lineageTag: 1cf64322-1858-4830-9d18-9cc1c2d6ef74

	measure Emprestimos_CP_floorplan_haikar = ```
			
			VAR UltimoDiaMesRecente = 
			    EOMONTH(MAX(dCalendario[data]), 0)
			
			VAR PrimeiroDiaMesRecente = 
			    DATE(YEAR(UltimoDiaMesRecente), MONTH(UltimoDiaMesRecente), 1)
			
			VAR emprestimo =
			    CALCULATE(
			        SUMX(
			            FILTER(
			                balancetenew,
			                balancetenew[Query] = "Emprestimos_Financiamentos_Curto_Prazo" &&
			                (
			                    balancetenew[descricao_cliente] = "CTA GARANTIDA HDA FLOORPLAN US"
			                   // balancetenew[descricao_cliente] = ""
			                )
			            ),
			            balancetenew[total_mes_atual]
			        ),
			        dCalendario[data] >= PrimeiroDiaMesRecente && dCalendario[data] <= UltimoDiaMesRecente
			    )
			
			VAR juros =
			    CALCULATE(
			        SUMX(
			            FILTER(
			                balancetenew,
			                balancetenew[Query] = "Emprestimos_Financiamentos_Curto_Prazo" &&
			                (
			                    balancetenew[descricao_cliente] = "CTA GARANTIDA HDA FLOORPLAN US"
			                )
			            ),
			            balancetenew[total_mes_atual]
			        ),
			        dCalendario[data] >= PrimeiroDiaMesRecente && dCalendario[data] <= UltimoDiaMesRecente
			    )
			
			RETURN emprestimo
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: cd14c6f6-8829-4676-af4b-19fd349f8658

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure 'emprestimos_CP_LM floorplan' =
			
			COALESCE(
			CALCULATE(
			    [Emprestimos_CP_floorplan_haikar], DATEADD(dCalendario[data], -1, MONTH))
			    , 0 )
