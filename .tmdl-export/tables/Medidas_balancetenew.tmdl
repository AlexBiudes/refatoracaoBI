	measure TributosIncidentes|ReceitaBruta = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			    COALESCE(
			CALCULATE(
			    DIVIDE(
			        SUMX(
			            'Medidas_balancetenew', 
			            'Medidas_balancetenew'[TributosIncidentes]
			        ), 
			            SUMX(
			                Medidas_balancetenew,
			                Medidas_balancetenew[MReceita_bruta]
			            )
			    ),
			                dCalendario[data] = UltimoMesTrimestre
			), 0)
