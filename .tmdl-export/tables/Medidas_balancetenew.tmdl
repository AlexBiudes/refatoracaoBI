			        ),
			        balancetenew[vlr]
			    ),
			    FILTER(
			        ALL(dCalendario[data]),
			        dCalendario[data] = EOMONTH(MAX(dCalendario[data]), -2) + 1
			    )
			)
		formatString: #,0
