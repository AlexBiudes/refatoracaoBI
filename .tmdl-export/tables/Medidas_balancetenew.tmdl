	measure Narrativa_Ativos_Resumo = ```
			
			VAR Var_AT = [desvio%_ativo_total]
			VAR Var_AC = [desvio%_ativo_circulante]
			VAR Var_ANC = [desvio%_ativo_n_circulante]
			
			VAR AC_Sent = IF(Var_AC >= 0, "crescimento", "queda")
			VAR ANC_Sent = IF(Var_ANC >= 0, "leve alta", "retração")
			VAR AT_Sent = IF(Var_AT >= 0, "expansão", "redução")
			
			RETURN
			"
			<div style='font-family:Segoe UI; font-size:13px; padding:4px;'>
			<b>Análise Horizontal dos Ativos</b><br><br>
			
			O <b>Ativo Total</b> apresentou <b>" & AT_Sent & "</b> de 
			<span style='color:" & IF(Var_AT>=0,"green","red") & "'>" &
			FORMAT(Var_AT,"0.00%") & "</span>, refletindo os movimentos combinados dos
			grupos circulante e não circulante.<br><br>
			
			O <b>Ativo Circulante</b> mostrou <b>" & AC_Sent & "</b> de 
			<span style='color:" & IF(Var_AC>=0,"green","red") & "'>" &
			FORMAT(Var_AC,"0.00%") & "</span>, influenciado principalmente pelas 
			contas de maior giro.<br><br>
			
			Já o <b>Ativo Não Circulante</b> registrou <b>" & ANC_Sent & "</b> de 
			<span style='color:" & IF(Var_ANC>=0,"green","red") & "'>" &
			FORMAT(Var_ANC,"0.00%") & "</span>, mantendo tendência estrutural do período.
			</div>"
			
			```
		lineageTag: dc77cffc-02b7-47ae-aa53-1d2297c0a5fc

	measure Narrativa_Ativos_Aumento = ```
			
			VAR _data_table =
			    FILTER(
			        ALL('balancetenew'),
			        'balancetenew'[Query] IN { 
			            "BL_AT_soma",
			            "BL_ATCIR_soma",
			            "BL_ATNCIR_soma"
			        }
			    )
			
			VAR RowMax =
			    TOPN(1, _data_table, [desvio%], DESC)
			
			VAR Nome =
			    CONCATENATEX(RowMax, 'balancetenew'[Query], ", ")
			
			VAR Valor =
			    MAXX(RowMax, [desvio%])
			
			RETURN
			"
			<div style='font-family:Segoe UI; font-size:13px; padding:4px;'>
			<b>Maior Crescimento:</b> 
			<span style='color:green; font-weight:bold;'>" &
			Nome & "</span> apresentou aumento de 
			<span style='color:green'>" &
			FORMAT(Valor, "0.00%") & "</span>, sendo o principal fator de impulso do 
			<b>Ativo Total</b> no período.
			</div>"
			
			```
		lineageTag: 1c83d679-b7fc-4b7d-94c6-b8f316e84ae2

