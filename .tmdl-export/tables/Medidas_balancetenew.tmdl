	measure BL_PASSCIR_Fornecedores = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			VAR vfornecedores =
			CALCULATE(
			SUMX(
			    FILTER(
			        balancetenew, 
			        balancetenew[Query] = "BL_PASSCIR_Fornecedores"
			    ), 
			    balancetenew[vlr]
			),
			dCalendario[data] = UltimoMesTrimestre
			)
			    RETURN
			IF(
			    vfornecedores < 0, vfornecedores *-1, vfornecedores
			)
			
			```
