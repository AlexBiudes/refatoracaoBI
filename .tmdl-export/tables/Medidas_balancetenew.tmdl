	measure caixasequicaixas = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			    COALESCE(IF(
			        CALCULATE(
			            SUMX(
			                FILTER(
			                    balancetenew,
			                    balancetenew[Query] = "BL_ATCIR_caixasequicaixas"
			                ),
			                balancetenew[total_mes_atual]
			            ),
			            dCalendario[data] = UltimoMesTrimestre
			        ) < 0,
			        CALCULATE(
			            SUMX(
			                FILTER(
			                    balancetenew,
			                    balancetenew[Query] = "BL_ATCIR_caixasequicaixas"
			                ),
			                balancetenew[total_mes_atual]
			            ),
			            dCalendario[data] = UltimoMesTrimestre
			        ) *-1, 
			        CALCULATE(
			            SUMX(
			                FILTER(
			                    balancetenew, 
			                    balancetenew[Query] = "BL_ATCIR_caixasequicaixas"
			                    ), 
			                    balancetenew[vlr]
			                    ),
			            dCalendario[data] = UltimoMesTrimestre
			        )
			), 0)
			```
