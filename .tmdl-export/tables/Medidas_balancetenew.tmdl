			        FORMAT(resultado_ly, "#,##0")
			    )
			RETURN
			    IF(
			        (resultado_ly = BLANK() && resultado_atual = BLANK()) || 
			        (resultado_ly = 0 && resultado_atual = 0),
			        BLANK(),
			        IF(
			            resultado_ly = BLANK() && resultado_atual <> 0,
			            "0",
			            resultado_ly_formatado
			        )
			    )
			```
