	measure gastos_gerais_video =
			
			VAR vdiferenca_margem_lucro =
			[MMargem_bruta] - [rresultado_operacional]
			 VAR vdespesas = [Ebitda_despesa_depreciacao]
			 VAR virpj_csll =
			  CALCULATE(
			    SUMX(FILTER(
			        balancetenew,
			        balancetenew[Query] = "DRE_Imposto_de_Renda" ||
			        balancetenew[Query] = "DRE_Contribuicao_Social"
			    ), balancetenew[vlr]))
			
			RETURN
			
			vdiferenca_margem_lucro
		lineageTag: 25c2ee77-f2b2-462e-b444-408155146475

		formatStringDefinition = ```
				VAR V_gastos = [gastos_gerais_video]
				VAR V_variacao = DIVIDE([gastos_gerais_video] - [gastos_gerais_LM], [gastos_gerais_LM])
				VAR V_formato = 
				SWITCH(
				    TRUE(),
				    V_gastos >= 1000000000, "R$ #,#0,0B;R$ -#,#0,0B",
				    V_gastos >= 1000000, "R$ #,#0,M; R$ -#,#0,M",
				    V_gastos >= 1000, "R$ #,#0,K;R$ -#,#0,K",
				    "R$ #,#0,.00;R$ -#,#0,0.00"
				)
				VAR V_icone = 
				IF(V_variacao > 0, " ⇡", " ⇣")
