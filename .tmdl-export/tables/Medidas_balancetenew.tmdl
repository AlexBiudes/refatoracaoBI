	measure financiamentos_LP =
			
			VAR UltimaDataSelecionada = LASTDATE(dcalendario[data])  // Armazena a última data selecionada no filtro
			RETURN
			COALESCE(
			CALCULATE(
			    SUMX(
			        FILTER(
			             balancetenew,
			             balancetenew[Query] = "BL_PASSNCIR_Emprestimos_Financiamentos" &&
			           (                balancetenew[descricao_cliente] = "FINANCIAMENTO BANCO SAFRA 135620 LP" ||
			                            balancetenew[descricao_cliente] = "BANCO J. SAFRA E LEASING . FINANCIAMENTO" ||
			                            balancetenew[descricao_cliente] = "( ) ENCARGOS FINANC BANCO SAFRA 135620"
			
			             ) &&
			            balancetenew[data] = UltimaDataSelecionada  // Filtra pela última data
			        ),
			        balancetenew[total_mes_atual]
			    )
			), 0)
		lineageTag: 8b98c71b-014e-442a-a375-f95114fbc2eb

		annotation PBI_FormatHint = {"isGeneralNumber":true}

