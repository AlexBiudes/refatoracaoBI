			                   // FINANCIAMENTO DE TERCEIROS LP
			                   // EMPRESTIMO BANCO ITAU
			                ),
			                balancetenew[total_mes_atual]
			            ),
			            dCalendario[data] >= PrimeiroDiaMesRecente && dCalendario[data] <= UltimoDiaMesRecente
			            )
			```
