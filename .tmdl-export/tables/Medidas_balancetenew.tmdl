	measure var_outras_receitas =
			
			VAR vreceitas =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DRE_Desp_Operacionais_Outras_receitas_operacionais"
			        ),
