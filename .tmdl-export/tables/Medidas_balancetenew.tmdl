	measure receita_liq_video = [MReceita_Liquida]
		lineageTag: b1df2c38-3b80-4017-8c4a-d9cd4af2b6e9

		formatStringDefinition = ```
				VAR V_receita = [MReceita_Liquida_actual_month]
				VAR V_variacao = 
				DIVIDE(
				    [MReceita_Liquida] - [MReceita_Liquida_LM_rentab],
				    [MReceita_Liquida_LM_rentab])
				VAR V_formato = 
				SWITCH(
				    TRUE(),
				    V_receita >= 1000000000, "R$ #,#0,0B;R$ -#,#0,0B",
				    V_receita >= 1000000, "R$ #,#0,M; R$ -#,#0,M",
				    V_receita >= 1000, "R$ #,#0,K;R$ -#,#0,K",
				    "R$ #,#0,.00;R$ -#,#0,0.00"
				)
				VAR V_icone = 
				IF(V_variacao > 0, " ⇡", " ⇣")
				RETURN
				"""" & FORMAT(V_receita, V_formato) & " | " &
				"""" & FORMAT(V_variacao, "0%;-0%") &
				V_icone
				
				
				
				```

