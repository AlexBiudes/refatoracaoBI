	measure totpassivo+PL = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			VAR v_passivo_circulante = CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			           balancetenew[Query] = "BL_PASSCIR_soma"
			        ),
			        balancetenew[total_mes_atual]
			    ), dCalendario[data] = UltimoMesTrimestre)
			
			VAR v_passivo_n_circulante = CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "BL_PASSNCIR_soma"
			        ),
			        balancetenew[total_mes_atual]
			    ), dCalendario[data] = UltimoMesTrimestre)  
			
			VAR v_PL = CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "BL_PL_soma"
			        ),
			        balancetenew[total_mes_atual]
			    ), dCalendario[data] = UltimoMesTrimestre)
			    RETURN
			CALCULATE(
			    IF( v_passivo_circulante > 0, v_passivo_circulante, v_passivo_circulante * -1) +
			        IF( v_passivo_n_circulante > 0, v_passivo_n_circulante, v_passivo_n_circulante * -1) +
			            IF( v_PL > 0, v_PL, v_PL * -1)
			    )
			```
		lineageTag: a4696033-1b71-4e0d-964e-969068017ce2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure saldo_passivo_balancetenew =
			
			VAR fornecedores =
			    SUMX(
			        VALUES(balancetenew[cnpj]),
			        VAR CNPJAtual = balancetenew[cnpj]
			        VAR ValorFornecedor =
			            CALCULATE(
			                SUM(balancetenew[vlr]),
			                balancetenew[Query] = "BL_PASSCIR_Fornecedores"
			            )
			        RETURN
			            IF(
			                CNPJAtual IN {
			                    "07543035000116",
			                    "17032154000168"
			                },
			                ValorFornecedor,
			                ABS(ValorFornecedor)
			            )
			    )
			
			VAR passivo_circulante =
			    CALCULATE(
			        SUM(balancetenew[vlr]),
			        balancetenew[Query] = "BL_PASSCIR_soma"
			    ) * -1
			
			VAR passivo_ncircuante =
			    CALCULATE(
			        SUM(balancetenew[vlr]),
			        balancetenew[Query] = "BL_PASSNCIR_soma"
			    ) * -1
			
			VAR todas_as_contas =
			    CALCULATE(
			        SUM(balancetenew[vlr]),
			        balancetenew[Query] <> "BL_PASSCIR_Fornecedores",
			        balancetenew[Query] <> "BL_PASSCIR_soma",
			        balancetenew[Query] <> "BL_PASSNCIR_soma"
			    )
			
			RETURN
			    passivo_circulante
			        + passivo_ncircuante
			        + fornecedores
			        + todas_as_contas
		formatString: #,0
		lineageTag: d71c5b1c-9e48-45dc-9ed5-a8260a7a22e3

		annotation PBI_FormatHint = {"isDecimal":true}

