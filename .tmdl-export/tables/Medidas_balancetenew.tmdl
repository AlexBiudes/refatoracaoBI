		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Timeline Capital de Giro HTML' =
			
			VAR PMP_  = COALESCE([Prazo Médio Contas a Pagar], 0)
			VAR PMR_  = COALESCE([Prazo Médio Contas a Receber], 0)
			VAR PMGE_ = COALESCE([prazo_medio_giro_estoque_aging], 0)
			
			-- marcos da timeline
			VAR DiaEntrada       = 0
			VAR DiaEstoque       = PMGE_
			VAR DiaPagamentos    = PMP_
			VAR DiaRecebimentos  = PMR_
			
			-- capital de giro conforme solicitado
			VAR DiasCapitalGiro  = PMR_ - PMP_
			
			VAR MaxDia =
			    MAX(
			        1,
			        MAX(
			            DiaEstoque,
			            MAX(DiaPagamentos, DiaRecebimentos)
			        )
			    )
			
			VAR PctEntradaNum      = DIVIDE(DiaEntrada, MaxDia, 0) * 100
			VAR PctEstoqueNum      = DIVIDE(DiaEstoque, MaxDia, 0) * 100
			VAR PctPagamentosNum   = DIVIDE(DiaPagamentos, MaxDia, 0) * 100
			VAR PctRecebimentosNum = DIVIDE(DiaRecebimentos, MaxDia, 0) * 100
			
			-- trecho azul do capital de giro: entre pagamentos e recebimentos
			VAR PctCGIniNum   = PctPagamentosNum
			VAR PctCGFimNum   = PctRecebimentosNum
			VAR PctCGLargNum  = PctCGFimNum - PctCGIniNum
			
			VAR PctEntrada      = SUBSTITUTE(FORMAT(PctEntradaNum, "0.0"), ",", ".")
			VAR PctEstoque      = SUBSTITUTE(FORMAT(PctEstoqueNum, "0.0"), ",", ".")
			VAR PctPagamentos   = SUBSTITUTE(FORMAT(PctPagamentosNum, "0.0"), ",", ".")
			VAR PctRecebimentos = SUBSTITUTE(FORMAT(PctRecebimentosNum, "0.0"), ",", ".")
			VAR PctCGIni        = SUBSTITUTE(FORMAT(PctCGIniNum, "0.0"), ",", ".")
			VAR PctCGLarg       = SUBSTITUTE(FORMAT(PctCGLargNum, "0.0"), ",", ".")
			
			RETURN
			"
			<div style='
			    font-family:Segoe UI, Arial, sans-serif;
			    background:#ffffff;
			    border:1px solid #E6EAF0;
			    border-radius:8px;
			    padding:16px 18px 14px 18px;
			    box-sizing:border-box;
			    width:100%;
			    min-height:210px;
			    color:#23384D;
			'>
			
			    <div style='font-size:15px; font-weight:600; color:#26435C; margin-bottom:10px;'>
			        Timeline do Capital de Giro
			    </div>
			
			    <div style='font-size:11px; font-weight:600; color:#6B7A8C; margin-bottom:16px;'>
			        Este período
			    </div>
			
			    <div style='display:flex; gap:20px; align-items:center;'>
			
			        <div style='flex:1; min-width:0;'>
			            <div style='position:relative; height:130px;'>
			
			                <!-- linha base -->
			                <div style='
			                    position:absolute;
			                    left:0;
			                    right:0;
			                    top:58px;
			                    height:3px;
			                    background:#BFC9D4;
			                    border-radius:999px;
			                '></div>
			
			                <!-- seta da linha -->
			                <div style='
			                    position:absolute;
			                    right:-1px;
			                    top:54px;
			                    width:0;
			                    height:0;
			                    border-top:5px solid transparent;
			                    border-bottom:5px solid transparent;
			                    border-left:12px solid #BFC9D4;
			                '></div>
			
			                <!-- trecho capital de giro -->
			                <div style='
			                    position:absolute;
			                    left:" & PctCGIni & "%;
			                    width:" & PctCGLarg & "%;
			                    top:57px;
			                    height:4px;
			                    background:#2D9CDB;
			                    border-radius:999px;
			                '></div>
			
			                <!-- Entrada -->
			                <div style='position:absolute; left:calc(" & PctEntrada & "% - 3px); top:34px;'>
			                    <div style='width:6px; height:28px; background:#2F80ED; border-radius:999px;'></div>
			                </div>
			                <div style='position:absolute; left:" & PctEntrada & "%; top:6px; transform:translateX(-8%); font-size:10px; color:#6B7A8C; font-weight:600; white-space:nowrap;'>
			                    Dia 0
			                </div>
			                <div style='position:absolute; left:" & PctEntrada & "%; top:72px; transform:translateX(-8%); font-size:10px; color:#6B7A8C; text-align:left; width:88px; line-height:1.25;'>
			                    Entradas nos<br/>Estoques
			                </div>
			
			                <!-- Estoque vendido -->
			                <div style='position:absolute; left:calc(" & PctEstoque & "% - 3px); top:34px;'>
			                    <div style='width:6px; height:28px; background:#F2994A; border-radius:999px;'></div>
			                </div>
			                <div style='position:absolute; left:" & PctEstoque & "%; top:6px; transform:translateX(-50%); font-size:10px; color:#6B7A8C; font-weight:600; white-space:nowrap;'>
			                    Dia " & FORMAT(DiaEstoque, "0") & "
			                </div>
			                <div style='position:absolute; left:" & PctEstoque & "%; top:72px; transform:translateX(-50%); font-size:10px; color:#6B7A8C; text-align:center; width:86px; line-height:1.25;'>
			                    Estoque<br/>Vendido
			                </div>
			
			                <!-- Fornecedores pagos -->
			                <div style='position:absolute; left:calc(" & PctPagamentos & "% - 3px); top:34px;'>
