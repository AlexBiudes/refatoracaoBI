	measure Ano_Atual_ = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			    MAX(dCalendario[Ano]),
			    ALL(dCalendario),
			    VALUES(dCalendario[Ano]
			    ),
			    dCalendario[data] = UltimoMesTrimestre
			)
			```
		formatString: 0
		lineageTag: ed26cbcd-2823-45ab-a667-1fdca6f744f0

