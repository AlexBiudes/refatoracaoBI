	measure Emprestimos_CP = ```
			
			VAR UltimoDiaMesRecente = 
			    EOMONTH(MAX(dCalendario[data]), 0)
			
			VAR PrimeiroDiaMesRecente = 
			    DATE(YEAR(UltimoDiaMesRecente), MONTH(UltimoDiaMesRecente), 1)
			
			VAR emprestimo =
			    CALCULATE(
			        SUMX(
			            FILTER(
			                balancetenew,
			                balancetenew[Query] = "Emprestimos_Financiamentos_Curto_Prazo" &&
			                (
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU 2258595129" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO BANCO ITAU" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU 2281764577" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO BANCO ALFA" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU 2258593744" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO BANCO J. SAFRA SA" ||
			                    balancetenew[descricao_cliente] = "BANCO SAFRA - GARANTIDA" ||
			                    balancetenew[descricao_cliente] = "FINANCIAMENTO DE TERCEIROS" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU 33426.77014" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU 5619.77012" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU 1591844" ||
			                    balancetenew[descricao_cliente] = "EMPRESTIMO CAPITAL DE GIRO ITAU"
			                   // balancetenew[descricao_cliente] = "
			                )
			            ),
			            balancetenew[total_mes_atual]
			        ),
			        dCalendario[data] >= PrimeiroDiaMesRecente && dCalendario[data] <= UltimoDiaMesRecente
			    )
			
			VAR juros =
			    CALCULATE(
			        SUMX(
			            FILTER(
			                balancetenew,
			                balancetenew[Query] = "Emprestimos_Financiamentos_Curto_Prazo" &&
			                (
			                    balancetenew[descricao_cliente] = "( - ) ENCARGOS CAPITAL DE GIRO ITAU 2258595129" ||
			                    balancetenew[descricao_cliente] = "( - ) ENCARGOS CAPITAL DE GIRO ITAU 2258593744" ||
			                    balancetenew[descricao_cliente] = "( - ) ENCARGOS CAPITAL DE GIRO ITAU 2281764577" ||
			                    balancetenew[descricao_cliente] = "( - ) ENCARGOS EMPRESTIMO BANCO J. SAFRA SA" ||
			                    balancetenew[descricao_cliente] = "( - ) ENCARGOS CAPITAL DE GIRO ITAU"
			                )
			            ),
			            balancetenew[total_mes_atual]
			        ),
			        dCalendario[data] >= PrimeiroDiaMesRecente && dCalendario[data] <= UltimoDiaMesRecente
			    )
			
			RETURN emprestimo + juros
			```
		formatString: "R$"\ #,0;-"R$"\ #,0;"R$"\ #,0
		lineageTag: 1c6fe2b6-9116-445b-963c-5db5a9821ffb

		annotation PBI_FormatHint = {"currencyCulture":"pt-BR"}

	measure emprestimos_LP = ```
			
			VAR UltimoDiaMesRecente = 
			    EOMONTH(MAX(dCalendario[data]), 0)
			
			VAR PrimeiroDiaMesRecente = 
