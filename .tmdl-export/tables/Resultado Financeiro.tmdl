		sourceColumn: Tipo Resultado

		annotation SummarizationSetBy = Automatic

	partition 'Resultado Financeiro' = m
		mode: import
		source =
				let
				    Fonte = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i45WcglyjXdJLS5ILU6MT8vMS8xLTs0sSlTSUYIKFiu4wUWLlWJ1IDqCUoECJWg6oIJoOmIB", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Query = _t, #"Tipo Resultado" = _t])
				in
