	measure %_estoque_acumulado = ```
			
			
			VAR v_estoque_acumulado =
			CALCULATE(
			    [estoque_valor_total$],
			    TOPN(
			        [rankig_produtos],
			        ALL(
			            F_estoques_ABC[Descrição]),
			            medidas_estoque_ABC[estoque_valor_total$],
			            DESC
			        )
			)
			RETURN
			   v_estoque_acumulado / 
			CALCULATE(
			    [estoque_valor_total$],
			    ALL(F_estoques_ABC[Descrição]))
			
			```
		formatString: 0.00%;-0.00%;0.00%
