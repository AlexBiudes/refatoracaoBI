	measure estoque_ABC =
			
			CALCULATE(
			    [estoque_valor_total$],
			    FILTER(
			        VALUES(F_estoques_ABC[Descrição]),
			        [%_estoque_acumulado] <= MAX(d_classe_abc[limite_superior]) &&
			        [%_estoque_acumulado] > MIN(d_classe_abc[limite_inf])
			    )
			)
