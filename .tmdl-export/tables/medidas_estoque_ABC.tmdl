	measure volumetria_estoque_abc =
			
			IF(NOT(ISBLANK(medidas_estoque_ABC[total_estoque])), "🟢", "🔴")
		lineageTag: 8ee151b0-2d1a-43fe-bdba-1749c2f960eb

	measure resumo_grupo_A = ```
			
			VAR vquant_itens = CALCULATE(
			DISTINCTCOUNT(d_produtos_estoques_ABC[descricao]),
			    FILTER(
			        ALL(F_estoques_ABC),
			        F_estoques_ABC[ABC] = "A"
			    )
			)
			
			VAR vcusto_grupo_A =
			    CALCULATE(
			     SUM(F_estoques_ABC[Valor Total]),
			    FILTER(F_estoques_ABC,
			            F_estoques_ABC[ABC] = "A"
			    ))
			
			VAR vcusto_grupo_A_perc = DIVIDE(
			    [custo_total_produto_A$],
			    [estoque_valor_total$]
			)
			
			RETURN
			"""" & "Os" & vquant_itens &  " " & "do GRUPO A tem um custo total de " & vcusto_grupo_A &  " representando" &  " do total em estoque."  
			```
		lineageTag: eadb622e-e4d0-4886-9938-3eb975a2db26

