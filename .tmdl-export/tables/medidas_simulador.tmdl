	measure deducoes_impostos_simulado = ```
			
			VAR vdeducoes_impostos_receita =
			ROUND(
			DIVIDE([deducoes_impostos],
			[MReceita_bruta]), 4)
			
			VAR vdeducoes_var_receita =
			CALCULATE(
			vdeducoes_impostos_receita * 
			[var_receita_bruta$] )
			
			RETURN
			
			    vdeducoes_var_receita 
			    + [deducoes_impostos]
			
			```
		formatString: #,0
		lineageTag: 45eacd73-e966-42d8-a665-50d4a2988d4e

		annotation PBI_FormatHint = {"isDecimal":true}

	measure simulador_switch_DRE = ```
			
			
			    SWITCH(
			        SELECTEDVALUE(d_mascara_DRE[NÍVEL 1]),
			        "Receita Bruta", [receita_bruta_simulado],
			        "(-) Deduções da Receita Bruta", [deducoes_impostos_simulado],
			        "Receita Líquida", [receita_liquida_simulado],
			        "(-) Custos dos Produtos Vendidos", [custo_simulado],
			        "(-) Custos dos Serviços Vendidos", [custo_simulado],
			        "Margem Bruta", [lucro_bruto_simulado],
			        "(-) Despesas Gerais", [despesas_gerais_simulado],
			        "Resultado Operacional", [lucro_operacional_simulado],
			        BLANK()
			    )
			
			
			
			```
