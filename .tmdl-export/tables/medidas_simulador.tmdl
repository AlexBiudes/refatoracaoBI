			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DFC_VARPAT_Contas_Receber"),
			            balancetenew[vlr]),
			            DATESYTD(dCalendario[data]))
			
			
			RETURN
			
			vvar_contas_receb_simu + ([var_receita_bruta_ACU$] *-1) + ([simulador_reduc_dias_CR] *-1)
		formatString: #,0
		lineageTag: a2cbdffb-51ea-485f-8dfe-baa08058c533

