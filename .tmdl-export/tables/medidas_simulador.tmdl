	measure prazo_medio_giro_do_estoque_simulado_TOTAL = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			VAR ResultadoCalculo = 
			    CALCULATE(
			        Medidas_balancetenew[ATCIR_Estoques] / 
			        Medidas_balancetenew[CCusto_ACU] * Medidas_balancetenew[Valor_mensal] * -1,
			        dCalendario[data] = UltimoMesTrimestre
			    ) + [Valor Simulador_PME]
			RETURN
			    ROUND(ResultadoCalculo, 2)
			
			```
