	measure variacao_estoque_DRE =
			
			// a variação do estoque tem como sua contra partida os custos.
			// os custos variados pela quantidade (demanda) terão seu aumento com base na proporção original dos custos
			
			VAR vreceita_bruta_simulado =
			([lucro_bruto_actual_month] * (1 + simulador_quantidade[Valor Var Qtd]) - [lucro_bruto_actual_month]) + [MReceita_bruta]
			
			VAR vvar_receita_bruta =
			 vreceita_bruta_simulado - [MReceita_bruta]
			
			VAR vcusto_var_receita =
			[CCusto|Receitabruta] * vvar_receita_bruta
			
			RETURN
			vcusto_var_receita *-1
		lineageTag: 6516a3fd-3dab-4c0d-a957-1324ec7166ab

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure variacao_estoques_total =
			
			VAR resultado =
			[variacao_estoque_DRE] +
			[simulador_red_dias_estoque]
			
			RETURN
			IF(
			            resultado >= -0.0001 && resultado <= 0.0001,
			            0, resultado)
