		formatStringDefinition = ```
				VAR V_lucro = [lucro_liquido_simulado] - [LLucro_liquido_actual_month]
				VAR V_variacao = DIVIDE(V_lucro, [LLucro_liquido_actual_month])
				
				VAR V_formato = 
				SWITCH(
				    TRUE(),
				    V_lucro >= 1000000000, "R$ #,##0.0B;R$ -#,##0.0B",
				    V_lucro >= 1000000, "R$ #,##0.0M; R$ -#,##0.0M",
				    V_lucro >= 1000, "R$ #,##0.0K;R$ -#,##0.0K",
				    "R$ #,##0;R$ -#,##0"
				)
				
				VAR V_icone = IF(V_variacao > 0, " ⇡", " ⇣")
				
				RETURN
				"""" & FORMAT(V_lucro, V_formato) & " | " &
				"""" & FORMAT(V_variacao, "0%;-0%") &
				V_icone
				
				
				
				```

