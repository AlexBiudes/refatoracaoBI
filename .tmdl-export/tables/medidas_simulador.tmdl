	measure variacao_estoques_video_simulado_ACU = ```
			
			VAR v_variacao =
			    CALCULATE(
			        DIVIDE(
			            [dfc_var_estoque_simulado_ACU] - [dfc_estoque_ACU],
			           ABS( [dfc_estoque_ACU])
			        )
			    )
			
			VAR v_seta =
			    IF(
			        v_variacao > 0, "🡑",
			        IF(v_variacao < 0, "🡓", "•")
			    )
			
			VAR v_variacao_din =
			    ([dfc_var_estoque_simulado_ACU] - [dfc_estoque_ACU])
			
			VAR v_variacao_din_if =
			    IF(
			        v_variacao_din >= -0.0001 && v_variacao_din <= 0.0001,
			        0, 
			        v_variacao_din
			    )
			
			VAR V_formato_moeda = 
			    SWITCH(
			        TRUE(),
			        v_variacao_din >= 1000000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        "R$ #,#0,;R$ -#,#0,0"
			    )
			
			VAR v_formato_seta =
			    SWITCH(
			        TRUE(),
			        v_seta = "🡑", "GREEN",  
			        v_seta = "🡓", "RED",
			        v_seta = "•", "BLACK"
			    )
			
			RETURN
			    FORMAT(v_variacao_din_if, V_formato_moeda)
			    & " | " &
			    FORMAT(v_seta, v_formato_seta) & " " &  
			    FORMAT(v_variacao, "0.00%;-0.00%")
			```
		lineageTag: 584d9c38-89f0-4a24-bed4-fc38ac9ab180

	measure variacao_contas_receber_video_simulado_ACU = ```
			
			VAR v_variacao =
			    CALCULATE(
			        DIVIDE(
			            [dfc_var_contas_receber_simulado_ACU] - [dfc_contas_receber_ACU],
			            [dfc_contas_receber_ACU]
			        )
			    )
			
			VAR v_seta =
			    IF(
			        ABS([dfc_var_contas_receber_simulado_ACU] - [dfc_contas_receber_ACU]) < 0.0001, "•", 
			        IF(
			            v_variacao > 0, "🡑", 
			            "🡓"
			        )
			    )
			
			VAR v_variacao_din =
			    [dfc_var_contas_receber_simulado_ACU] - [dfc_contas_receber_ACU]
			
			VAR v_variacao_din_if =
			    IF(
			        v_variacao_din >= -0.0001 && v_variacao_din <= 0.0001,
			        0, v_variacao_din
			    )
			
			VAR v_formato_moeda = 
			    SWITCH(
			        TRUE(),
			        v_variacao_din >= 1000000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        "R$ #,#0,;R$ -#,#0,0"
			    )
			
			VAR v_formato_seta =
			    SWITCH(
			        TRUE(),
			        v_seta = "🡑", "GREEN",  
			        v_seta = "🡓", "RED",
			        v_seta = "•", "BLACK"  -- Define a cor para o "-"
			    )
			
			RETURN
			
			FORMAT(v_variacao_din_if, v_formato_moeda)
			& " | " &
