	measure deducoes_simulado = ```
			
			VAR vdeducoes_impostos_receita =
			ROUND(
			DIVIDE([deducoes_actual_month],
			[MReceita_bruta]), 4)
			
			VAR vdeducoes_var_receita =
			CALCULATE(
			vdeducoes_impostos_receita * 
			[var_receita_bruta$] )
			
			RETURN
			
			    vdeducoes_var_receita 
			    + [deducoes_actual_month]
			```
