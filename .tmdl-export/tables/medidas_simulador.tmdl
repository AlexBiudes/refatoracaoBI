	measure dfc_switch_simulado = ```
			
			CALCULATE(
			SWITCH (
			    SELECTEDVALUE(d_mascara_dfc[classificação]),
			    "lucro_prejuizo_liq", [total_mes_atual],
			    "ajustes_nao_afetam_caixa", [total_mes_atual],
			"depreciaçao", [total_mes_atual],
			"agio", [total_mes_atual],
			"resultado_acumulado", [desvio],
			"resultado_equivalencia_patrim", [total_mes_atual],
