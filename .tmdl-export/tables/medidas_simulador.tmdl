	measure dfc_variacao_operacional_outras_contas = ```
			
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			VAR vvariacao_total =
			CALCULATE(
			    SUMX(
			        FILTER(balancetenew,
			        balancetenew[Query] = "DFC_VARPAT_TOTAL"),
			        balancetenew[vlr]),
			        dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			
			        RETURN
			
			        vvariacao_total - [dfc_contas_pagar_actual_month] - [dfc_contas_receber_actual_month] - [dfc_estoque_actual_month]
			```
		formatString: #,0
		lineageTag: 565f56f0-772a-42c0-b4cb-25c81a1f24a3

		annotation PBI_FormatHint = {"isDecimal":true}

	measure variacao_estoques_video_simulado = ```
			
			VAR v_variacao =
			    CALCULATE(
			        DIVIDE(
			            [dfc_var_estoque_simulado] - [dfc_estoque_actual_month],
			           ABS( [dfc_estoque_actual_month])
			        )
			    )
			
			VAR v_seta =
			    IF(
			        v_variacao > 0, "🡑",
			        IF(v_variacao < 0, "🡓", "•")
			    )
			
			VAR v_variacao_din =
			    ([dfc_var_estoque_simulado] - [dfc_estoque_actual_month])
			
			VAR v_variacao_din_if =
			    IF(
			        v_variacao_din >= -0.0001 && v_variacao_din <= 0.0001,
			        0, 
			        v_variacao_din
			    )
			
			VAR V_formato_moeda = 
			    SWITCH(
			        TRUE(),
			        v_variacao_din >= 1000000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        "R$ #,#0,;R$ -#,#0,0"
			    )
			
			VAR v_formato_seta =
			    SWITCH(
			        TRUE(),
			        v_seta = "🡑", "GREEN",  
			        v_seta = "🡓", "RED",
			        v_seta = "•", "BLACK"
			    )
			
			RETURN
			    FORMAT(v_variacao_din_if, V_formato_moeda)
			    & " | " &
			    FORMAT(v_seta, v_formato_seta) & " " &  
			    FORMAT(v_variacao, "0.00%;-0.00%")
			
			```
		lineageTag: 7a6b078c-9289-454a-9039-7ab20e0c2634

