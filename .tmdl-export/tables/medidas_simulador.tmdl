	measure variacao_receita_bruta_video_simulado = ```
			
			VAR v_variacao =
			    CALCULATE(
			        DIVIDE(
			            [receita_bruta_simulado] - [MReceita_bruta],
			            [MReceita_bruta]
			        )
			    )
			
			VAR v_seta =
			    IF(
			        ABS([receita_bruta_simulado] - [MReceita_bruta]) < 0.0001, "•", 
			        IF(
			            v_variacao >= 0, "🡑", "🡓"
			        )
			    )
			
			VAR v_variacao_din =
			    [receita_bruta_simulado] - [MReceita_bruta]
			
			VAR v_variacao_din_if =
			    IF(
			        v_variacao_din >= -0.0001 && v_variacao_din <= 0.0001,
			        0, v_variacao_din
			    )
			
			VAR V_formato_moeda = 
			    SWITCH(
			        TRUE(),
			        ABS(v_variacao_din) >= 1000000000, "R$ #,,,#0;R$ -#,,,#0",
			        ABS(v_variacao_din) >= 1000000, "R$ #,,#0;R$ -#,,#0",
			        ABS(v_variacao_din) >= 1000, "R$ #,#0;R$ -#,#0",
			        "R$ #,##0;R$ -#,##0"
			    )
			
			VAR v_formato_seta =
			    SWITCH(
			        TRUE(),
			        v_seta = "🡑", "GREEN",  
			        v_seta = "🡓", "RED",
			        v_seta = "•", "BLACK"  -- Define a cor para "•"
			    )
			
			RETURN
			
			FORMAT(v_variacao_din_if, V_formato_moeda)
			& " | " &
			FORMAT(v_seta, v_formato_seta) & " " &  
			FORMAT(v_variacao, "0.00%;-0.00%")
			
			```
		lineageTag: 2e307f59-161a-443a-ac8f-fd46adfb2b4a

