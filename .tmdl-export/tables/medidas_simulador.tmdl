	measure variacao_lucro_liquido_video_simulado = ```
			
			VAR v_variacao =
			    CALCULATE(
			        DIVIDE(
			            [lucro_liquido_simulado] - [LLucro_liquido_actual_month],
			            [LLucro_liquido_actual_month]
			        )
			    )
			
			VAR v_seta =
			    IF(
			        ABS([lucro_liquido_simulado] - [LLucro_liquido_actual_month]) < 0.0001, "•", 
			        IF(
			            v_variacao >= 0, "🡑", "🡓"
			        )
			    )
			
			VAR v_variacao_din =
			    [lucro_liquido_simulado] - [LLucro_liquido_actual_month]
			
			VAR v_variacao_din_if =
			    IF(
			        v_variacao_din >= -0.0001 && v_variacao_din <= 0.0001,
			        0, 
			        v_variacao_din
			    )
			
			VAR V_formato_moeda = 
			    SWITCH(
			        TRUE(),
			        v_variacao_din >= 1000000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        "R$ #,#0,;R$ -#,#0,0"
			    )
			
			VAR v_formato_seta =
			    SWITCH(
			        TRUE(),
			        v_seta = "🡑", "GREEN",  
			        v_seta = "🡓", "RED",
			        v_seta = "•", "BLACK"
			    )
			
			RETURN
			
			FORMAT(v_variacao_din_if, V_formato_moeda)
			& " | " &
			FORMAT(v_seta, v_formato_seta) & " " &  
			FORMAT(v_variacao, "0.00%;-0.00%")
			
			```
		lineageTag: 71ac0701-2d5b-408a-a162-e2fefb86926b

