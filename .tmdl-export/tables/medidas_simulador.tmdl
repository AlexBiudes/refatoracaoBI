table medidas_simulador
	lineageTag: 2a9a6632-8f0d-431a-85c1-327935a501bc

	measure receita_bruta_simulado = ```
			
			VAR variacao_qtd =
			([lucro_bruto_actual_month] * (1 + simulador_quantidade[Valor Var Qtd])) - [lucro_bruto_actual_month]
			 
			 VAR variacao_preco =
			 [MReceita_bruta] * (1 + simulador_preco[Valor Preço] )
			
			 RETURN
			 variacao_qtd + variacao_preco
			```
		formatString: #,0
		lineageTag: 15de1317-af88-4281-bc32-65a0dc53d83b

		annotation PBI_FormatHint = {"isDecimal":true}

	measure simulador_quantidade =
			
			[MMargem_bruta]
		formatString: #,0
		lineageTag: 2c504d21-f803-4933-8c89-e6fcd7fcbb1c

		annotation PBI_FormatHint = {"isDecimal":true}

	measure simulador_variacao_margem_bruta =
			
			[MMargem_bruta_actual_month] - [MMargem_brutaLM]
		formatString: #,0
		lineageTag: ae90970d-3f21-4b74-bfd0-ae8deb71a61f

		annotation PBI_FormatHint = {"isDecimal":true}

	measure custo_simulado = ```
			
			VAR vreceita_bruta_simulado =
			([lucro_bruto_actual_month] * (1 + simulador_quantidade[Valor Var Qtd]) - [lucro_bruto_actual_month]) + [MReceita_bruta]
			
			VAR vvar_receita_bruta =
			 vreceita_bruta_simulado - [MReceita_bruta]
			
			VAR vcusto_var_receita =
			[CCusto|Receitabruta] * vvar_receita_bruta
			 
			 VAR vvariacao_custos =
			 [CCusto_actual_month] * (1 + simulador_custos[Valor simulador_custos]) *-1
			
			 RETURN
			 vcusto_var_receita + vvariacao_custos
			```
		formatString: #,0
		lineageTag: 1ebf1e2e-7212-4dfb-8304-596a5d4e8536

		annotation PBI_FormatHint = {"isDecimal":true}

	measure despesas_gerais_simulado =
			
			VAR resultado =
			[despesas_gerais_simples] * (1 + simulador_despesas_gerais[Valor simulador_despesas_gerais])
			
			RETURN
			IF(
			            resultado >= -0.0001 && resultado <= 0.0001,
			            0, resultado)
		formatString: #,0
		lineageTag: 5b9a2316-5447-48f6-bef9-bb1186f2a4d5

		annotation PBI_FormatHint = {"isDecimal":true}

	measure lucro_operacional_simulado = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			    RETURN
			    CALCULATE(
			[lucro_bruto_simulado] - [despesas_gerais_simulado],
			dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			```
		formatString: #,0
		lineageTag: 626fb6e6-c704-47df-8139-41e5b8297632

		annotation PBI_FormatHint = {"isDecimal":true}

	measure despesas_gerais_actual_month = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    
			RETURN
			CALCULATE(
			SUMX(
			    FILTER(balancetenew,
			    balancetenew[Query] = "DRE_Desp_Operacional_Despesas_Vendas" ||
			    balancetenew[Query] = "DRE_Desp_Operacional_Despesas_Variaveis_Vendas" ||
			    balancetenew[Query] = "DRE_Desp_Operacional_Despesas_Folha_Vendas" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_comerciais" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Marketplace" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_pessoal_Salarios_ordenados" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_Marketing" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Marketing" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_pessoal_Beneficios" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_pessoal_Impostos" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_pessoal_Provisoes" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_pessoal" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_administrativas" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_Folha_administrativas" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_Centro_Distribuicao" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_Variaveis_Entrega" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_Folha_Centro_Distribuicao" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Logistica" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Consultoria_Tecnica" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Alugueis" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Prestacao_de_Servicos" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Manutencoes" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Informatica" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Ocupacao" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_contratuais" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_depreciacao" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_tributarias" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_controladas" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_nao_controladas"
			    ),
			    balancetenew[vlr]
			),
			dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			
			```
		formatString: #,0
		lineageTag: 4d52f252-2b9a-4bbc-b704-59e013c2bf15

