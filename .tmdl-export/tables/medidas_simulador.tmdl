	measure dfc_resultado_ajustado_simulado_ACU =
			
			VAR vresultado_ajust =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DFC_Resultado_Ajustado"
			        ),
			        balancetenew[vlr]
			    ),
			    DATESYTD(dCalendario[data]))
			
			VAR vvar_lucro =
			    [lucro_liquido_simulado_ACU] - [LLucro_liquido_ACU]
			
			RETURN
			    vresultado_ajust + vvar_lucro
		formatString: #,0
		lineageTag: bc71a3d3-5dc0-4fee-aaff-a20547fc33bf

		annotation PBI_FormatHint = {"isDecimal":true}

	measure dfc_var_estoque_simulado_ACU =
			
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DFC_VARPAT_Estoques"),
			            balancetenew[vlr]),
			            DATESYTD(dCalendario[data]))
			             + ([variacao_estoques_total_ACU] *-1)
		lineageTag: ad46acc3-8e17-475e-935b-89f846b78df7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure variacao_estoques_total_ACU =
			
			VAR resultado =
			[variacao_estoque_DRE_ACU] +
			[simulador_red_dias_estoque] // incluir a variacao de estoque acumulada
			
			RETURN
			IF(
			            resultado >= -0.0001 && resultado <= 0.0001,
			            0, resultado)
		formatString: #,0
		lineageTag: b9c1f914-209a-433e-96dc-01f4d6b53855

		annotation PBI_FormatHint = {"isDecimal":true}

	measure variacao_estoque_DRE_ACU =
			
			// a variação do estoque tem como sua contra partida os custos.
			// os custos variados pela quantidade (demanda) terão seu aumento com base na proporção original dos custos
			
			VAR vreceita_bruta_simulado =
			([MMargem_Bruta_ACU] * (1 + simulador_quantidade[Valor Var Qtd]) - [MMargem_Bruta_ACU]) + [MReceita_Bruta_ACU]
			
			VAR vvar_receita_bruta =
			 vreceita_bruta_simulado - [MReceita_Bruta_ACU]
			
			VAR vcusto_var_receita =
			[CCusto|Receitabruta_ACU] * vvar_receita_bruta
			
			RETURN
			vcusto_var_receita *-1
		formatString: #,0
		lineageTag: 83b160cf-d16d-4447-a7bb-3684f355dcef

		annotation PBI_FormatHint = {"isDecimal":true}

	measure dfc_var_contas_receber_simulado_ACU =
			
			VAR vvar_contas_receb_simu =
