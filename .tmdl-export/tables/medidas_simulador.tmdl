	measure CCusto_actual_month_positivo = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			    RETURN
			CALCULATE(
			    SUMX(
			    FILTER(
			        balancetenew, 
			        balancetenew[Query] = "Custo dos Produtos Vendidos"
			    ), 
			        balancetenew[vlr]
			    ),
			dCalendario[data] = UltimoMesTrimestre
			) *-1
			```
		formatString: #,0
		lineageTag: 800f41e5-15f2-4aa6-a6ce-ab7876453126

		annotation PBI_FormatHint = {"isDecimal":true}

