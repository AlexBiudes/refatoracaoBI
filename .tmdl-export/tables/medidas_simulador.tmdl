	measure dfc_resultado_ajustado_simulado = ```
			
			VAR UltimoDiaTrimestre = 
			    LASTDATE(
			        DATESINPERIOD(
			            dCalendario[data], 
			            MAX(dCalendario[data]), -3, 
			            QUARTER
			        )
			    )
			VAR UltimoMesTrimestre = 
			    EOMONTH(UltimoDiaTrimestre,-1)+1
			
			VAR vresultado_ajust =
			CALCULATE(
			    SUMX(
			        FILTER(
			            balancetenew,
			            balancetenew[Query] = "DFC_Resultado_Ajustado"
			        ),
			        balancetenew[vlr]
			    ),
			    dCalendario[data] >= UltimoMesTrimestre && dCalendario[data] <= UltimoDiaTrimestre)
			
			
			VAR vvar_lucro =
			    [lucro_liquido_simulado] - [LLucro_liquido_actual_month]
			
			RETURN
			    vresultado_ajust + vvar_lucro
			
			```
