	measure despesas_gerais_acu_ano_civil =
			
			CALCULATE(
			SUMX(
			    FILTER(balancetenew,
			    balancetenew[Query] = "DRE_Desp_Operacional_Despesas_Vendas" ||
			    balancetenew[Query] = "DRE_Desp_Operacional_Despesas_Variaveis_Vendas" ||
			    balancetenew[Query] = "DRE_Desp_Operacional_Despesas_Folha_Vendas" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_comerciais" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_Marketplace" ||
			    balancetenew[Query] = "DRE_Desp_Operacionais_Despesas_com_pessoal_Salarios_ordenados" ||
