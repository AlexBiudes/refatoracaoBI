	measure variacao_receita_bruta_video_simulado_ACU = ```
			
			VAR v_variacao =
			    CALCULATE(
			        DIVIDE(
			            [receita_bruta_simulado_acu] - [MReceita_Bruta_ACU],
			            [MReceita_Bruta_ACU]
			        )
			    )
			
			VAR v_seta =
			    IF(
			        v_variacao >= 0, "🡑", "🡓"
			    )
			
			VAR v_variacao_din =
			    [receita_bruta_simulado_acu] - [MReceita_Bruta_ACU]
			
			VAR v_variacao_din_if =
			IF(
			            v_variacao_din >= -0.0001 && v_variacao_din <= 0.0001,
			            0, v_variacao_din)
			
			VAR V_formato_moeda = 
			    SWITCH(
			        TRUE(),
			        v_variacao_din >= 1000000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        v_variacao_din >= 1000, "R$ #,#,#0,0;R$ -#,#,#0,0",
			        "R$ #,#0,;R$ -#,#0,0"
			    )
			
			VAR v_formato_seta =
			    SWITCH(
			        TRUE(),
			        v_seta = "🡑", "GREEN",  
			        v_seta = "🡓", "RED",
			        v_seta = "•", "BLACK"
			    )
			
			RETURN
			
			FORMAT(v_variacao_din_if, V_formato_moeda)
			& " | " &
			FORMAT(v_seta, v_formato_seta) & " " &  
			FORMAT(v_variacao, "0.00%;-0.00%")
			```
		lineageTag: baf641e0-07ab-445f-86bd-4369ad8a3a83

